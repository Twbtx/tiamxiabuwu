-- ========== 甩飞一次 + 循环甩飞（完整 SkidFling 逻辑，带预测） ==========
local function FlingPlayer(targetPlayer)
    if not targetPlayer then
        ShowNotification("未选择目标", Color3.fromRGB(255, 50, 50))
        return
    end

    local char = player.Character
    if not char then
        ShowNotification("角色未就绪", Color3.fromRGB(255, 50, 50))
        return
    end

    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = hum and hum.RootPart
    if not root then
        ShowNotification("角色未就绪", Color3.fromRGB(255, 50, 50))
        return
    end

    local tChar = targetPlayer.Character
    if not tChar then
        ShowNotification("目标无角色", Color3.fromRGB(255, 50, 50))
        return
    end

    local tHum = tChar:FindFirstChildOfClass("Humanoid")
    local tRoot = tHum and tHum.RootPart
    local tHead = tChar:FindFirstChild("Head")
    local acc = tChar:FindFirstChildOfClass("Accessory")
    local handle = acc and acc:FindFirstChild("Handle")

    if not (tRoot or tHead or handle) then
        ShowNotification("目标缺少部件", Color3.fromRGB(255, 50, 50))
        return
    end

    -- 甩飞时使用预测位置
    local targetPredPos = tRoot and GetPredictedPosition(tRoot) or tRoot.Position

    local oldCam = workspace.CurrentCamera.CameraSubject
    if tHead then
        workspace.CurrentCamera.CameraSubject = tHead
    elseif handle then
        workspace.CurrentCamera.CameraSubject = handle
    elseif tHum then
        workspace.CurrentCamera.CameraSubject = tHum
    end

    local oldFPDH = workspace.FallenPartsDestroyHeight
    workspace.FallenPartsDestroyHeight = 0/0

    local selfPos = root.CFrame

    local function FPos(basePart, pos, ang)
        root.CFrame = CFrame.new(basePart.Position) * pos * ang
        char:SetPrimaryPartCFrame(CFrame.new(basePart.Position) * pos * ang)
        root.Velocity = Vector3.new(9e7, 9e7 * 10, 9e7)
        root.RotVelocity = Vector3.new(9e8, 9e8, 9e8)
    end

    local function SFBasePart(basePart)
        local timeToWait = 2
        local startTime = tick()
        local angle = 0

        repeat
            if not root or not tHum then break end

            if basePart.Velocity.Magnitude < 50 then
                angle = angle + 100
                FPos(basePart, CFrame.new(0, 1.5, 0) + tHum.MoveDirection * basePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(angle), 0, 0))
                task.wait()
                FPos(basePart, CFrame.new(0, -1.5, 0) + tHum.MoveDirection * basePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(angle), 0, 0))
                task.wait()
                FPos(basePart, CFrame.new(2.25, 1.5, -2.25) + tHum.MoveDirection * basePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(angle), 0, 0))
                task.wait()
                FPos(basePart, CFrame.new(-2.25, -1.5, 2.25) + tHum.MoveDirection * basePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(angle), 0, 0))
                task.wait()
                FPos(basePart, CFrame.new(0, 1.5, 0) + tHum.MoveDirection, CFrame.Angles(math.rad(angle), 0, 0))
                task.wait()
                FPos(basePart, CFrame.new(0, -1.5, 0) + tHum.MoveDirection, CFrame.Angles(math.rad(angle), 0, 0))
                task.wait()
            else
                FPos(basePart, CFrame.new(0, 1.5, tHum.WalkSpeed), CFrame.Angles(math.rad(90), 0, 0))
                task.wait()
                FPos(basePart, CFrame.new(0, -1.5, -tHum.WalkSpeed), CFrame.Angles(0, 0, 0))
                task.wait()
                FPos(basePart, CFrame.new(0, 1.5, tHum.WalkSpeed), CFrame.Angles(math.rad(90), 0, 0))
                task.wait()
                FPos(basePart, CFrame.new(0, 1.5, tRoot.Velocity.Magnitude / 1.25), CFrame.Angles(math.rad(90), 0, 0))
                task.wait()
                FPos(basePart, CFrame.new(0, -1.5, -tRoot.Velocity.Magnitude / 1.25), CFrame.Angles(0, 0, 0))
                task.wait()
                FPos(basePart, CFrame.new(0, 1.5, tRoot.Velocity.Magnitude / 1.25), CFrame.Angles(math.rad(90), 0, 0))
                task.wait()
                FPos(basePart, CFrame.new(0, -1.5, 0), CFrame.Angles(math.rad(90), 0, 0))
                task.wait()
                FPos(basePart, CFrame.new(0, -1.5, 0), CFrame.Angles(0, 0, 0))
                task.wait()
                FPos(basePart, CFrame.new(0, -1.5, 0), CFrame.Angles(math.rad(-90), 0, 0))
                task.wait()
                FPos(basePart, CFrame.new(0, -1.5, 0), CFrame.Angles(0, 0, 0))
                task.wait()
            end
        until basePart.Velocity.Magnitude > 500 or not basePart.Parent or not targetPlayer.Character or targetPlayer.Parent ~= Players or tHum.Sit or hum.Health <= 0 or tick() > startTime + timeToWait
    end

    local bv = Instance.new("BodyVelocity")
    bv.Name = "EpixVel"
    bv.Parent = root
    bv.Velocity = Vector3.new(9e8, 9e8, 9e8)
    bv.MaxForce = Vector3.new(1/0, 1/0, 1/0)

    hum:SetStateEnabled(Enum.HumanoidStateType.Seated, false)

    local targetPartForFling = tRoot or tHead or handle
    if targetPartForFling then
        local originalPos = targetPartForFling.Position
        targetPartForFling.Position = targetPredPos
        if tRoot and tHead and (tRoot.CFrame.p - tHead.CFrame.p).Magnitude > 5 then
            SFBasePart(tHead)
        elseif tRoot then
            SFBasePart(tRoot)
        elseif tHead then
            SFBasePart(tHead)
        elseif handle then
            SFBasePart(handle)
        else
            ShowNotification("目标缺失部件", Color3.fromRGB(255, 50, 50))
        end
        targetPartForFling.Position = originalPos
    else
        ShowNotification("目标缺失部件", Color3.fromRGB(255, 50, 50))
    end

    bv:Destroy()
    hum:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
    workspace.CurrentCamera.CameraSubject = oldCam or hum
    workspace.FallenPartsDestroyHeight = oldFPDH

    root.CFrame = selfPos
    char:SetPrimaryPartCFrame(selfPos)
    root.Velocity = Vector3.zero
    root.RotVelocity = Vector3.zero
end

