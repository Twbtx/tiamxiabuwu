-- ========== 预测核心（动态：速度 × 延迟时间） ==========
local function GetPredictedPosition(rootPart)
    if not Teleport.PredictEnabled then
        return rootPart.Position
    end
    local vel = rootPart.AssemblyLinearVelocity
    if vel.Magnitude < 0.5 then
        return rootPart.Position
    end
    return rootPart.Position + vel * Teleport.PredictDelay
end

-- ========== 传送（带预测） ==========
local function TeleportRoutine()
    if not Teleport.Active then return end

    local myChar = player.Character
    local targetChar = Teleport.Target and Teleport.Target.Character

    if not myChar or not targetChar then
        StopTeleport()
        return
    end

    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")

    if myRoot and targetRoot then
        local targetPos = GetPredictedPosition(targetRoot)
        local newPos = Vector3.new(targetPos.X, targetPos.Y - 5.5, targetPos.Z)
        myRoot.CFrame = CFrame.new(newPos, targetPos)
    end
end

-- ========== 平行环绕（带预测） ==========
local function ParallelOrbitRoutine()
    if not Teleport.HorizontalOrbitActive then return end

    local myChar = player.Character
    local targetChar = Teleport.Target and Teleport.Target.Character

    if not myChar or not targetChar then
        StopParallelOrbit()
        return
    end

    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")

    if myRoot and targetRoot then
        local centerPos = GetPredictedPosition(targetRoot)
        Teleport.HorizontalAngle = Teleport.HorizontalAngle + Teleport.HorizontalSpeed * 0.05
        local radius = Teleport.OrbitRadius

        local x = centerPos.X + math.cos(Teleport.HorizontalAngle) * radius
        local z = centerPos.Z + math.sin(Teleport.HorizontalAngle) * radius

        local raycastParams = RaycastParams.new()
        raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
        raycastParams.FilterDescendantsInstances = {myChar}

        local raycastResult = Workspace:Raycast(Vector3.new(x, centerPos.Y + 10, z), Vector3.new(0, -50, 0), raycastParams)
        local y = raycastResult and raycastResult.Position.Y or centerPos.Y

        local newPos = Vector3.new(x, y + 3, z)
        myRoot.CFrame = CFrame.new(newPos, centerPos)
    end
end

