local function startTeleportLoop(enemyChar, enemyRoot)
    local startTime = tick()
    local myChar = player.Character
    if not myChar then return end

    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end

    local myHum = myChar:FindFirstChild("Humanoid")
    if not myHum then return end

    local enemyHum = enemyChar:FindFirstChild("Humanoid")
    if not enemyHum then return end

    myHum.PlatformStand = true
    local fixedOffset = randomOffset()

    local myPos = myRoot.Position
    local enemyPos = enemyRoot.Position
    local dirToEnemy = (enemyPos - myPos).Unit
    local facePos = enemyPos - dirToEnemy * SupaTech.FaceDistance
    facePos = Vector3.new(facePos.X, enemyPos.Y, facePos.Z)

    myRoot.CFrame = CFrame.new(facePos + fixedOffset) * CFrame.Angles(math.rad(SupaTech.UpwardAngle), 0, 0)
    task.wait(0.1)

    local footPos = enemyRoot.Position - Vector3.new(0, SupaTech.TeleportOffset, 0)
    myRoot.CFrame = CFrame.new(footPos + fixedOffset) * CFrame.Angles(math.rad(SupaTech.UpwardAngle), 0, 0)

    while tick() - startTime < SupaTech.TeleportDuration do
        if not SupaTech.Enabled then break end
        if not enemyRoot or not enemyRoot.Parent then break end
        if not myRoot or not myRoot.Parent then break end
        if not myHum then break end

        local currentEnemyHum = enemyChar:FindFirstChild("Humanoid")
        if not currentEnemyHum then break end

        if isPlayingAnim(currentEnemyHum, SupaTech.EndAnimId) or isPlayingAnim(currentEnemyHum, SupaTech.RagdollAnimId) then
            break
        end

        local newFootPos = enemyRoot.Position - Vector3.new(0, SupaTech.TeleportOffset, 0)
        myRoot.CFrame = CFrame.new(newFootPos + fixedOffset) * CFrame.Angles(math.rad(SupaTech.UpwardAngle), 0, 0)
        task.wait()
    end

    if enemyRoot and enemyRoot.Parent and myRoot and myRoot.Parent then
        local finalFootPos = enemyRoot.Position - Vector3.new(0, SupaTech.VerticalOffset, 0)
        myRoot.CFrame = CFrame.new(finalFootPos + fixedOffset) * CFrame.Angles(math.rad(SupaTech.UpwardAngle), 0, 0)
    end

    myHum.PlatformStand = false
end

local function executeSupaTech()
    if SupaTech.IsExecuting then return end
    if SupaTech.IsCooldown then return end

    SupaTech.IsExecuting = true
    local enemyChar, enemyRoot = getNearestEnemy()

    if not enemyChar or not enemyRoot then
        SupaTech.IsExecuting = false
        return
    end

    local enemyHumCheck = enemyChar:FindFirstChild("Humanoid")
    if enemyHumCheck and (isPlayingAnim(enemyHumCheck, SupaTech.RagdollAnimId) or isPlayingAnim(enemyHumCheck, SupaTech.EndAnimId)) then
        SupaTech.IsExecuting = false
        return
    end

    task.wait(SupaTech.WaitBeforeAction)

    if not enemyChar.Parent or not enemyRoot.Parent then
        SupaTech.IsExecuting = false
        return
    end

    local enemyHum2 = enemyChar:FindFirstChild("Humanoid")
