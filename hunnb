local function ToggleTouchFling()
    Teleport.TouchFlingActive = not Teleport.TouchFlingActive
    TouchFlingButton.Text = Teleport.TouchFlingActive and "触碰甩飞: 开启" or "触碰甩飞: 关闭"

    local indicator = TouchFlingButton:FindFirstChild("Indicator")
    if indicator then
        indicator.BackgroundColor3 = Teleport.TouchFlingActive and Color3.fromRGB(50, 255, 50) or Color3.fromRGB(255, 50, 50)
    end

    if Teleport.TouchFlingActive then
        if Teleport.TouchFlingThread then return end
        Teleport.TouchFlingThread = task.spawn(function()
            local flingPower = 2500
            local movel = 0.05
            while Teleport.TouchFlingActive do
                RunService.Heartbeat:Wait()
                local character = player.Character
                if not character then continue end
                local hrp = character:FindFirstChild("HumanoidRootPart")
                if not hrp then continue end
                local originalVelocity = hrp.Velocity
                hrp.Velocity = originalVelocity * 1.5 + Vector3.new(0, flingPower, 0)
                RunService.RenderStepped:Wait()
                hrp.Velocity = originalVelocity * 0.8
                RunService.Stepped:Wait()
                hrp.Velocity = originalVelocity + Vector3.new(0, movel, 0)
                movel = -movel
            end
            Teleport.TouchFlingThread = nil
        end)
        ShowNotification("触碰甩飞已启动（走路创人）", Color3.fromRGB(0, 200, 255))
    else
        if Teleport.TouchFlingThread then
            task.cancel(Teleport.TouchFlingThread)
            Teleport.TouchFlingThread = nil
        end
        ShowNotification("触碰甩飞已停止", Color3.fromRGB(255, 100, 0))
    end
end

