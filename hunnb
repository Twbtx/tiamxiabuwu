local function randomOffset()
    local angle = math.random() * math.pi * 2
    local dist = math.random() * SupaTech.RandomRadius
    return Vector3.new(math.cos(angle) * dist, 0, math.sin(angle) * dist)
end

local function isPlayingAnim(hum, animId)
    if not hum then return false end
    for _, track in ipairs(hum:GetPlayingAnimationTracks()) do
        local anim = track.Animation
        if anim then
            local id = anim.AnimationId
            if id and string.find(id, animId) then
                return true
            end
        end
    end
    return false
end

local function getNearestEnemy()
    local char = player.Character
    if not char then return nil, nil end

    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil, nil end

    local nearest = nil
    local nearestRoot = nil
    local nearestDist = math.huge
    local myPos = root.Position

    for _, other in ipairs(Players:GetPlayers()) do
        if other ~= player then
            local oChar = other.Character
            if oChar then
                local oRoot = oChar:FindFirstChild("HumanoidRootPart")
                if oRoot then
                    local dist = (myPos - oRoot.Position).Magnitude
                    if dist < nearestDist then
                        nearestDist = dist
                        nearest = oChar
                        nearestRoot = oRoot
                    end
                end
            end
        end
    end

    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= char then
            local hum = obj:FindFirstChild("Humanoid")
            local oRoot = obj:FindFirstChild("HumanoidRootPart")
            if hum and oRoot then
                local dist = (myPos - oRoot.Position).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    nearest = obj
                    nearestRoot = oRoot
                end
            end
        end
    end

    if nearest and nearestRoot then
        return nearest, nearestRoot
    end
    return nil, nil
end

