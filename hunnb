local AntiFling = {
    Enabled = false,
    MaxLinear = 200,
    MaxAngular = 100,
    SafeCFrame = nil,
    BodyMovers = {"BodyVelocity", "BodyAngularVelocity", "BodyForce", "BodyThrust", "BodyPosition", "BodyGyro"},
    Conns = {}
}

local function FlingNeutralize()
    local char = player.Character
    if not char then return end

    for _, obj in ipairs(char:GetDescendants()) do
        if table.find(AntiFling.BodyMovers, obj.ClassName) then
            pcall(function() obj:Destroy() end)
        end
    end

    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = false
            part.AssemblyLinearVelocity = Vector3.zero
            part.AssemblyAngularVelocity = Vector3.zero
            part.Velocity = Vector3.zero
            part.RotVelocity = Vector3.zero
        end
    end

    local root = char:FindFirstChild("HumanoidRootPart")
    if root and AntiFling.SafeCFrame then
        root.CFrame = AntiFling.SafeCFrame
        char:SetPrimaryPartCFrame(AntiFling.SafeCFrame)
    end

    task.delay(0.4, function()
        if char and char.Parent then
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = true
                end
            end
        end
    end)

    ShowNotification("检测到被甩飞，已 neutralize", Color3.fromRGB(255, 100, 0))
end

local function WatchBodyMovers(char)
    local con = char.DescendantAdded:Connect(function(child)
        if not AntiFling.Enabled then return end
        if table.find(AntiFling.BodyMovers, child.ClassName) then
            child:Destroy()
            ShowNotification("拦截异常 " .. child.ClassName, Color3.fromRGB(255, 100, 0))
            FlingNeutralize()
        end
    end)
    table.insert(AntiFling.Conns, con)
end

local function AntiFlingHeartbeat()
    if not AntiFling.Enabled then return end

    local char = player.Character
    if not char then return end

    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local linear = root.AssemblyLinearVelocity.Magnitude
    local angular = root.AssemblyAngularVelocity.Magnitude

    if linear < 60 and angular < 40 then
        AntiFling.SafeCFrame = root.CFrame
    end

    if linear > AntiFling.MaxLinear or angular > AntiFling.MaxAngular then
        FlingNeutralize()
    end
end

local function SetupAntiFling(char)
    for _, con in ipairs(AntiFling.Conns) do
        pcall(function() con:Disconnect() end)
    end
    AntiFling.Conns = {}
    task.wait(0.3)
    if char and char.Parent then
        WatchBodyMovers(char)
    end
end

