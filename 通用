    local function applyBlackWhiteFlowingBorder(borderFrame)
        if not borderFrame or not borderFrame:IsA("Frame") then
            warn("applyBlackWhiteFlowingBorder: 参数必须是 Frame")
            return function() end
        end

        local outerStroke = Instance.new("UIStroke")
        outerStroke.Name = "Border_OuterStroke"
        outerStroke.Color = BORDER_COLOR
        outerStroke.Thickness = BORDER_THICKNESS
        outerStroke.Transparency = 0
        outerStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        outerStroke.Parent = borderFrame

        local gradient = Instance.new("UIGradient")
        gradient.Name = "Border_Gradient"
        gradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 0, 0)),
            ColorSequenceKeypoint.new(0.3, Color3.fromRGB(100, 100, 100)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 255, 255)),
            ColorSequenceKeypoint.new(0.7, Color3.fromRGB(100, 100, 100)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 0, 0))
        })
        gradient.Transparency = NumberSequence.new(0.3)
        gradient.Parent = outerStroke

        local running = true
        local time = 0

        local heartbeatConnection = RunService.Heartbeat:Connect(function(deltaTime)
            if not running or not borderFrame.Parent then
                heartbeatConnection:Disconnect()
                return
            end
            time = time + deltaTime
            gradient.Rotation = (gradient.Rotation + 30 * deltaTime) % 360
            gradient.Offset = Vector2.new((math.sin(time * 2) * 0.5), 0)
            gradient.Transparency = NumberSequence.new(0.2 + math.sin(time * 3) * 0.1)
        end)

        return function()
            running = false
            if heartbeatConnection then
                heartbeatConnection:Disconnect()
            end
            if outerStroke then
                outerStroke:Destroy()
            end
        end
    end

    local function closeNotificationWithSlide(notifRoot, autoCloseFlagRef)
