function XrayController:Initialize()
    self.Connections.playerAdded = Players.PlayerAdded:Connect(function(plr)
        if plr ~= self.LocalPlayer then
            wait(1)
            if self.HighlightEnabled or self.NameEnabled or self.BoxEnabled or self.HealthBarEnabled then
                self:CreateESPForPlayer(plr)
            end
        end
    end)
    
    self.Connections.playerRemoving = Players.PlayerRemoving:Connect(function(plr)
        self:CleanupPlayerESP(plr)
    end)
    
    RunService.RenderStepped:Connect(function()
        if self.HighlightEnabled or self.NameEnabled or self.BoxEnabled or self.HealthBarEnabled then
            self:UpdateAllESP()
        end
    end)
end

function XrayController:Cleanup()
    self:DisableHighlight()
    self:DisableName()
    self:DisableBox()
    self:DisableHealthBar()
    
    for _, conns in pairs(self.Connections) do
        if type(conns) == "table" then
            for _, conn in pairs(conns) do
                if conn and typeof(conn) == "RBXScriptConnection" then
                    conn:Disconnect()
                end
            end
        elseif typeof(conns) == "RBXScriptConnection" then
            conns:Disconnect()
        end
    end
    
    if self.Storage then
        self.Storage:Destroy()
    end
    if self.ScreenGui then
        self.ScreenGui:Destroy()
    end
end

