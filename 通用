-- ==================== 修复：自定义通知系统（始终置顶） ====================
do
    local Players = game:GetService("Players")
    local player = Players.LocalPlayer
    local guiService = game:GetService("GuiService")
    local TweenService = game:GetService("TweenService")
    local RunService = game:GetService("RunService")
    local CoreGui = game:GetService("CoreGui")          -- 改用 CoreGui

    -- 通知样式配置
    local NOTIF_WIDTH = 250
    local NOTIF_HEIGHT = 55
    local BORDER_THICKNESS = 2
    local BOTTOM_MARGIN = 10
    local RIGHT_MARGIN = 10
    local SPACING = 8
    local ANIMATION_DURATION = 0.25
    local AUTO_CLOSE_DELAY = 5

    -- 资源ID
    local LEFT_ICON_ID = "120133762956711"
    local CLOSE_ICON_ID = "104269942650107"
    local NOTIFICATION_SOUND_ID = "1508145469"

    -- 颜色方案
    local BG_COLOR = Color3.fromRGB(25, 25, 25)
    local TEXT_COLOR = Color3.fromRGB(255, 255, 255)
    local TEXT_STROKE_COLOR = Color3.fromRGB(0, 0, 0)
    local BORDER_COLOR = Color3.fromRGB(255, 255, 255)

    local activeNotifications = {}
    local borderAnimations = {}

    -- 创建置顶 ScreenGui
    local function createScreenGui()
        local screenGui = Instance.new("ScreenGui")
        screenGui.Name = "NotificationManagerGui"
        screenGui.ResetOnSpawn = false
        screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Global   -- 全局模式
        screenGui.DisplayOrder = 999                            -- 最高显示顺序
        screenGui.Parent = CoreGui
        return screenGui
    end

    local mainGui = createScreenGui()

    local function tweenToPosition(frame, targetPosition, duration)
        local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        local tween = TweenService:Create(frame, tweenInfo, {Position = targetPosition})
        tween:Play()
        return tween
    end

    local function repositionAllNotifications(newNotificationFrame)
        local count = #activeNotifications
        for idx, notifRoot in ipairs(activeNotifications) do
            local orderFromBottom = count - idx
            local targetYOffset = -BOTTOM_MARGIN - orderFromBottom * (NOTIF_HEIGHT + SPACING)
            local targetXOffset = -RIGHT_MARGIN
            local targetPosition = UDim2.new(1, targetXOffset, 1, targetYOffset)

            if newNotificationFrame and notifRoot == newNotificationFrame then
                local startXOffset = targetXOffset + NOTIF_WIDTH + 20
                notifRoot.Position = UDim2.new(1, startXOffset, 1, targetYOffset)
                tweenToPosition(notifRoot, targetPosition, ANIMATION_DURATION)
            else
                tweenToPosition(notifRoot, targetPosition, ANIMATION_DURATION)
            end
        end
    end

    local function playNotificationSound()
        local sound = Instance.new("Sound")
        sound.SoundId = "rbxassetid://" .. NOTIFICATION_SOUND_ID
        sound.Volume = 0.5
        sound.PlayOnRemove = false
        sound.Parent = mainGui
        sound:Play()
        sound.Ended:Connect(function()
            sound:Destroy()
        end)
        task.delay(3, function()
            if sound and sound.Parent then
                sound:Destroy()
            end
        end)
    end

    local function applyBlackWhiteFlowingBorder(borderFrame)
        if not borderFrame or not borderFrame:IsA("Frame") then
            warn("applyBlackWhiteFlowingBorder: 参数必须是 Frame")
            return function() end
        end

        local outerStroke = Instance.new("UIStroke")
        outerStroke.Name = "Border_OuterStroke"
        outerStroke.Color = BORDER_COLOR
        outerStroke.Thickness = BORDER_THICKNESS
        outerStroke.Transparency = 0
        outerStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        outerStroke.Parent = borderFrame

        local gradient = Instance.new("UIGradient")
        gradient.Name = "Border_Gradient"
        gradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 0, 0)),
            ColorSequenceKeypoint.new(0.3, Color3.fromRGB(100, 100, 100)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 255, 255)),
            ColorSequenceKeypoint.new(0.7, Color3.fromRGB(100, 100, 100)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 0, 0))
        })
        gradient.Transparency = NumberSequence.new(0.3)
        gradient.Parent = outerStroke

        local running = true
        local time = 0

        local heartbeatConnection = RunService.Heartbeat:Connect(function(deltaTime)
            if not running or not borderFrame.Parent then
                heartbeatConnection:Disconnect()
                return
            end
            time = time + deltaTime
            gradient.Rotation = (gradient.Rotation + 30 * deltaTime) % 360
            gradient.Offset = Vector2.new((math.sin(time * 2) * 0.5), 0)
            gradient.Transparency = NumberSequence.new(0.2 + math.sin(time * 3) * 0.1)
        end)

        return function()
            running = false
            if heartbeatConnection then
                heartbeatConnection:Disconnect()
            end
            if outerStroke then
                outerStroke:Destroy()
            end
        end
    end

    local function closeNotificationWithSlide(notifRoot, autoCloseFlagRef)
        if not notifRoot or not notifRoot.Parent then
            return
        end
        if notifRoot:GetAttribute("IsClosing") then
            return
        end
        notifRoot:SetAttribute("IsClosing", true)

        if autoCloseFlagRef then
            autoCloseFlagRef.isActive = false
        end

        for i, existingRoot in ipairs(activeNotifications) do
            if existingRoot == notifRoot then
                table.remove(activeNotifications, i)
                break
            end
        end

        repositionAllNotifications(nil)

        local currentPos = notifRoot.Position
        local currentXOffset = currentPos.X.Offset
        local currentYOffset = currentPos.Y.Offset
        local slideOutXOffset = currentXOffset + NOTIF_WIDTH + 100
        local targetPosition = UDim2.new(1, slideOutXOffset, 1, currentYOffset)

        local slideTween = tweenToPosition(notifRoot, targetPosition, ANIMATION_DURATION)
        slideTween.Completed:Connect(function()
            if borderAnimations[notifRoot] then
                borderAnimations[notifRoot]()
                borderAnimations[notifRoot] = nil
            end
            notifRoot:Destroy()
        end)
    end

    local function createNotificationFrame(textContent)
        local borderFrame = Instance.new("Frame")
        borderFrame.BackgroundTransparency = 1
        borderFrame.BorderSizePixel = 0
        borderFrame.Size = UDim2.new(0, NOTIF_WIDTH, 0, NOTIF_HEIGHT)
        borderFrame.AnchorPoint = Vector2.new(1, 1)
        borderFrame.ClipsDescendants = true
        borderFrame.Name = "NotificationBorder"
        borderFrame.ZIndex = 100

        local cleanupAnimation = applyBlackWhiteFlowingBorder(borderFrame)
        borderAnimations[borderFrame] = cleanupAnimation

        local contentFrame = Instance.new("Frame")
        contentFrame.Name = "Content"
        contentFrame.BackgroundColor3 = BG_COLOR
        contentFrame.BackgroundTransparency = 0
        contentFrame.BorderSizePixel = 0
        contentFrame.Size = UDim2.new(1, 0, 1, 0)
        contentFrame.Position = UDim2.new(0, 0, 0, 0)
        contentFrame.ZIndex = 101
        contentFrame.Parent = borderFrame

        local leftIcon = Instance.new("ImageLabel")
        leftIcon.Size = UDim2.new(0, 40, 0, 40)
        leftIcon.Position = UDim2.new(0, 6, 0.5, -20)
        leftIcon.BackgroundTransparency = 1
        leftIcon.Image = "rbxassetid://" .. LEFT_ICON_ID
        leftIcon.ScaleType = Enum.ScaleType.Fit
        leftIcon.ZIndex = 102
        leftIcon.Parent = contentFrame

        local textLabel = Instance.new("TextLabel")
        textLabel.BackgroundTransparency = 1
        textLabel.TextColor3 = TEXT_COLOR
        textLabel.TextXAlignment = Enum.TextXAlignment.Left
        textLabel.TextYAlignment = Enum.TextYAlignment.Center
        textLabel.Font = Enum.Font.GothamBold
        textLabel.TextSize = 18
        textLabel.Text = textContent
        textLabel.TextWrapped = true
        textLabel.TextScaled = false
        textLabel.TextStrokeTransparency = 0
        textLabel.TextStrokeColor3 = TEXT_STROKE_COLOR
        textLabel.Size = UDim2.new(1, -75, 1, -8)
        textLabel.Position = UDim2.new(0, 52, 0, 4)
        textLabel.ZIndex = 102
        textLabel.Parent = contentFrame

        local closeBtn = Instance.new("ImageButton")
        closeBtn.Size = UDim2.new(0, 20, 0, 20)
        closeBtn.Position = UDim2.new(1, -24, 0, 6)
        closeBtn.BackgroundTransparency = 1
        closeBtn.Image = "rbxassetid://" .. CLOSE_ICON_ID
        closeBtn.ScaleType = Enum.ScaleType.Fit
        closeBtn.AutoButtonColor = true
        closeBtn.ZIndex = 103
        closeBtn.Parent = contentFrame

        local autoCloseFlag = { isActive = true }

        closeBtn.MouseButton1Click:Connect(function()
            if borderFrame:GetAttribute("IsClosing") then
                return
            end
            closeNotificationWithSlide(borderFrame, autoCloseFlag)
        end)

        task.delay(AUTO_CLOSE_DELAY, function()
            if not autoCloseFlag.isActive then
                return
            end
            if not borderFrame.Parent then
                return
            end
            if borderFrame:GetAttribute("IsClosing") then
                return
            end
            closeNotificationWithSlide(borderFrame, autoCloseFlag)
        end)

        return borderFrame
    end

    local function ShowNotification(messageText)
        playNotificationSound()
        local newRoot = createNotificationFrame(messageText)
        newRoot.Parent = mainGui
        table.insert(activeNotifications, newRoot)
        repositionAllNotifications(newRoot)
    end

    task.wait(1)
    ShowNotification("欢迎使用STAR，反挂机已自动开启")
    task.wait(2)
    ShowNotification("作者su7，QQ1693323219")
    task.wait(2)
    ShowNotification("脚本加载完整需要一定时间请耐心等待")

    _G.ShowToast = ShowNotification
end

