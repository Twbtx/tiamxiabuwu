-- 窗口关闭清理
Window:OnClose(function()
    if getgenv().QWGeneral.Threads.Aimbot then getgenv().QWGeneral.Threads.Aimbot:Disconnect() end
    if getgenv().QWGeneral.Threads.FOV then task.cancel(getgenv().QWGeneral.Threads.FOV) end
    if fovCircle then fovCircle:Destroy() end
    if _G.XrayController then _G.XrayController:Cleanup() end
    if rainbowBorderAnimation then
        rainbowBorderAnimation:Disconnect()
        rainbowBorderAnimation = nil
    end
    for _, animation in pairs(fontColorAnimations) do
        animation:Disconnect()
    end
    fontColorAnimations = {}
    applyBlurEffect(false)
end)