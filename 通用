    local function repositionAllNotifications(newNotificationFrame)
        local count = #activeNotifications
        for idx, notifRoot in ipairs(activeNotifications) do
            local orderFromBottom = count - idx
            local targetYOffset = -BOTTOM_MARGIN - orderFromBottom * (NOTIF_HEIGHT + SPACING)
            local targetXOffset = -RIGHT_MARGIN
            local targetPosition = UDim2.new(1, targetXOffset, 1, targetYOffset)

            if newNotificationFrame and notifRoot == newNotificationFrame then
                local startXOffset = targetXOffset + NOTIF_WIDTH + 20
                notifRoot.Position = UDim2.new(1, startXOffset, 1, targetYOffset)
                tweenToPosition(notifRoot, targetPosition, ANIMATION_DURATION)
            else
                tweenToPosition(notifRoot, targetPosition, ANIMATION_DURATION)
            end
        end
    end

