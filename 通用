    end
    
    if self.HealthBarEnabled then
        self:CreateHealthBar(plr)
    end
    
    if not self.Connections[plr] then
        self.Connections[plr] = {}
    end
    
    if self.Connections[plr].charAdded then
        self.Connections[plr].charAdded:Disconnect()
    end
    if self.Connections[plr].charRemoving then
        self.Connections[plr].charRemoving:Disconnect()
    end
    
    self.Connections[plr].charAdded = plr.CharacterAdded:Connect(function(char)
        wait(0.5)
        
        if self.HighlightEnabled and self.HighlightInstances[plr] then
            self.HighlightInstances[plr].Adornee = char
        end
        
        if self.NameEnabled then
            local head = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
            if head and self.BillboardInstances[plr] then
                self.BillboardInstances[plr].Adornee = head
                self.BillboardInstances[plr].Enabled = true
            end
        end
        
        if self.BoxEnabled then
            if not self.BoxInstances[plr] then
                self:CreateBoxESP(plr)
            else
                self:UpdateBoxESP(plr)
            end
        end
        
        if self.HealthBarEnabled then
            if not self.HealthBarInstances[plr] then
                self:CreateHealthBar(plr)
            end
        end
    end)
    
    self.Connections[plr].charRemoving = plr.CharacterRemoving:Connect(function()
        if self.HighlightInstances[plr] then
            self.HighlightInstances[plr].Adornee = nil
        end
        if self.BillboardInstances[plr] then
            self.BillboardInstances[plr].Enabled = false
        end
        if self.BoxInstances[plr] then
            self.BoxInstances[plr].Frame.Visible = false
        end
        if self.HealthBarInstances[plr] then
            self.HealthBarInstances[plr].Container.Visible = false
        end
    end)
end

function XrayController:UpdateAllESP()
    if self.HighlightEnabled then
        for plr, highlight in pairs(self.HighlightInstances) do
            if plr and plr.Parent and highlight then
                local char = plr.Character
                if char and highlight.Adornee ~= char then
                    highlight.Adornee = char
                end
            end
        end
    end
    
    if self.NameEnabled then
        for plr, billboard in pairs(self.BillboardInstances) do
            if plr and plr.Parent and billboard then
                local char = plr.Character
                if char then
                    local head = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
                    if head and billboard.Adornee ~= head then
                        billboard.Adornee = head
                        billboard.Enabled = true
                    end
                else
                    billboard.Enabled = false
                end
            end
        end
    end
    
    if self.BoxEnabled then
        for plr, boxData in pairs(self.BoxInstances) do
            if plr and plr.Parent then
                self:UpdateBoxESP(plr)
            end
        end
    end
    
    if self.HealthBarEnabled then
        self:UpdateAllHealthBars()
    end
end

function XrayController:CleanupPlayerESP(plr)
    if self.HighlightInstances[plr] then
        self.HighlightInstances[plr]:Destroy()
        self.HighlightInstances[plr] = nil
    end
    
    if self.BillboardInstances[plr] then
        self.BillboardInstances[plr]:Destroy()
        self.BillboardInstances[plr] = nil
    end
    
    if self.BoxInstances[plr] then
        self.BoxInstances[plr].Frame:Destroy()
        self.BoxInstances[plr] = nil
    end
    
    if self.HealthBarInstances[plr] then
        self:DestroyHealthBar(plr)
    end
    
    if self.Connections[plr] then
        for _, conn in pairs(self.Connections[plr]) do
            if conn and typeof(conn) == "RBXScriptConnection" then
                conn:Disconnect()
            end
        end
        self.Connections[plr] = nil
    end
end

