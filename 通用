local function TeleportToCoordinate()
    CreateCoordinateSelectionUI("选择要传送的坐标", function(coord)
        local character = LocalPlayer.Character
        if not character then
            WindUI:Notify({Title = "传送坐标", Content = "角色未找到", Duration = 2})
            return
        end

        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if not rootPart then
            WindUI:Notify({Title = "传送坐标", Content = "未找到HumanoidRootPart", Duration = 2})
            return
        end

        rootPart.CFrame = CFrame.new(coord.x, coord.y, coord.z)
        WindUI:Notify({Title = "传送坐标", Content = "已传送到: " .. coord.name, Duration = 2})
    end)
end

local function DeleteCoordinate()
    CreateCoordinateSelectionUI("选择要删除的坐标", function(coord, index)
        table.remove(SavedCoordinates, index)
        SaveCoordinates()
        WindUI:Notify({Title = "删除坐标", Content = "已删除坐标: " .. coord.name, Duration = 2})
    end, true)
end

