function XrayController:CreateBoxESP(plr)
    if plr == self.LocalPlayer then return end
    
    if self.BoxInstances[plr] then
        self.BoxInstances[plr].Frame:Destroy()
    end
    
    local boxFrame = Instance.new("Frame")
    boxFrame.Name = plr.Name .. "_Box"
    boxFrame.BackgroundTransparency = 1
    boxFrame.BorderSizePixel = 0
    boxFrame.Parent = self.ScreenGui
    
    local lines = {}
    local lineNames = {"Top", "Bottom", "Left", "Right"}
    
    for _, name in ipairs(lineNames) do
        local line = Instance.new("Frame")
        line.Name = name
        line.BackgroundColor3 = self.BoxColor
        line.BorderSizePixel = 0
        line.Parent = boxFrame
        table.insert(lines, line)
    end
    
    local outlines = {}
    for _, name in ipairs(lineNames) do
        local outline = Instance.new("Frame")
        outline.Name = name .. "_Outline"
        outline.BackgroundColor3 = self.BoxOutlineColor
        outline.BorderSizePixel = 0
        outline.ZIndex = -1
        outline.Parent = boxFrame
        table.insert(outlines, outline)
    end
    
    self.BoxInstances[plr] = {
        Frame = boxFrame,
        Lines = lines,
        Outlines = outlines,
        Player = plr
    }
    
    return self.BoxInstances[plr]
end

function XrayController:UpdateBoxESP(plr)
    local boxData = self.BoxInstances[plr]
    if not boxData then return end
    
    local character = plr.Character
    if not character then 
        boxData.Frame.Visible = false
        return 
    end
    
    local humanoid = character:FindFirstChild("Humanoid")
    local hrp = character:FindFirstChild("HumanoidRootPart")
    
    if not hrp or not humanoid or humanoid.Health <= 0 then
        boxData.Frame.Visible = false
        return
    end
    
    local minX, minY, minZ = math.huge, math.huge, math.huge
    local maxX, maxY, maxZ = -math.huge, -math.huge, -math.huge
    local validParts = 0
    
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            local pos = part.Position
            local size = part.Size / 2
            
            minX = math.min(minX, pos.X - size.X)
            minY = math.min(minY, pos.Y - size.Y)
            minZ = math.min(minZ, pos.Z - size.Z)
            maxX = math.max(maxX, pos.X + size.X)
            maxY = math.max(maxY, pos.Y + size.Y)
            maxZ = math.max(maxZ, pos.Z + size.Z)
            validParts = validParts + 1
        end
    end
    
    if validParts == 0 or minX == math.huge then
        boxData.Frame.Visible = false
        return
    end
    
    local corners = {
        Vector3.new(minX, minY, minZ),
        Vector3.new(minX, minY, maxZ),
        Vector3.new(minX, maxY, minZ),
        Vector3.new(minX, maxY, maxZ),
        Vector3.new(maxX, minY, minZ),
        Vector3.new(maxX, minY, maxZ),
        Vector3.new(maxX, maxY, minZ),
        Vector3.new(maxX, maxY, maxZ)
    }
    
    local minScreenX, minScreenY = math.huge, math.huge
    local maxScreenX, maxScreenY = -math.huge, -math.huge
    local validPoints = 0
    
    for _, corner in ipairs(corners) do
        local screenPos, onScreen = CurrentCamera:WorldToViewportPoint(corner)
        
        if screenPos.Z > 0 then
            minScreenX = math.min(minScreenX, screenPos.X)
            minScreenY = math.min(minScreenY, screenPos.Y)
            maxScreenX = math.max(maxScreenX, screenPos.X)
            maxScreenY = math.max(maxScreenY, screenPos.Y)
            validPoints = validPoints + 1
        end
    end
    
    if validPoints == 0 then
        boxData.Frame.Visible = false
        return
    end
    
    local viewportSize = CurrentCamera.ViewportSize
    local margin = 100
    
    if maxScreenX < -margin or minScreenX > viewportSize.X + margin or 
       maxScreenY < -margin or minScreenY > viewportSize.Y + margin then
        boxData.Frame.Visible = false
        return
    end
    
    local width = maxScreenX - minScreenX
    local height = maxScreenY - minScreenY
    
    if width > self.MaxBoxSize or height > self.MaxBoxSize then
        local centerX = (minScreenX + maxScreenX) / 2
        local centerY = (minScreenY + maxScreenY) / 2
        width = math.min(width, self.MaxBoxSize)
        height = math.min(height, self.MaxBoxSize)
        minScreenX = centerX - width / 2
        minScreenY = centerY - height / 2
    end
    
    if width < self.MinBoxSize then
        local centerX = (minScreenX + maxScreenX) / 2
        minScreenX = centerX - self.MinBoxSize / 2
        maxScreenX = centerX + self.MinBoxSize / 2
        width = self.MinBoxSize
    end
    
    if height < self.MinBoxSize then
        local centerY = (minScreenY + maxScreenY) / 2
        minScreenY = centerY - self.MinBoxSize / 2
        maxScreenY = centerY + self.MinBoxSize / 2
        height = self.MinBoxSize
    end
    
    boxData.Frame.Visible = true
    boxData.Frame.Position = UDim2.new(0, minScreenX, 0, minScreenY)
    boxData.Frame.Size = UDim2.new(0, width, 0, height)
    
    local thickness = self.BoxThickness
    local outlineThickness = thickness + 2
    
    local lines = boxData.Lines
    local outlines = boxData.Outlines
    
    lines[1].Position = UDim2.new(0, 0, 0, 0)
    lines[1].Size = UDim2.new(1, 0, 0, thickness)
    lines[2].Position = UDim2.new(0, 0, 1, -thickness)
    lines[2].Size = UDim2.new(1, 0, 0, thickness)
    lines[3].Position = UDim2.new(0, 0, 0, 0)
    lines[3].Size = UDim2.new(0, thickness, 1, 0)
    lines[4].Position = UDim2.new(1, -thickness, 0, 0)
    lines[4].Size = UDim2.new(0, thickness, 1, 0)
    
    outlines[1].Position = UDim2.new(0, -1, 0, -1)
    outlines[1].Size = UDim2.new(1, 2, 0, outlineThickness)
    outlines[2].Position = UDim2.new(0, -1, 1, -outlineThickness + 1)
    outlines[2].Size = UDim2.new(1, 2, 0, outlineThickness)
    outlines[3].Position = UDim2.new(0, -1, 0, -1)
    outlines[3].Size = UDim2.new(0, outlineThickness, 1, 2)
    outlines[4].Position = UDim2.new(1, -outlineThickness + 1, 0, -1)
    outlines[4].Size = UDim2.new(0, outlineThickness, 1, 2)
end

function XrayController:CreateHealthBar(plr)
    if plr == self.LocalPlayer then return end
    
    if self.HealthBarInstances[plr] then
        self:DestroyHealthBar(plr)
    end
    
    self:EnsureStorage()
    
    local container = Instance.new("Frame")
    container.Name = plr.Name .. "_HealthBar"
    container.Size = UDim2.new(0, self.HealthBarWidth, 0, self.HealthBarHeight)
    container.BackgroundColor3 = self.HealthBarBgColor
    container.BackgroundTransparency = 0.5
    container.BorderSizePixel = 1
    container.BorderColor3 = Color3.fromRGB(0, 0, 0)
    container.Visible = true
    container.ZIndex = 2
    container.Parent = self.ScreenGui
    
    local fill = Instance.new("Frame")
    fill.Name = "Fill"
    fill.Size = UDim2.new(1, 0, 1, 0)
    fill.BackgroundColor3 = self.HealthBarFillColor
    fill.BorderSizePixel = 0
    fill.BackgroundTransparency = 0
    fill.Parent = container
    
    self.HealthBarInstances[plr] = {
        Container = container,
        Fill = fill
    }
    
    return container
end

function XrayController:DestroyHealthBar(plr)
    if self.HealthBarInstances[plr] then
        if self.HealthBarInstances[plr].Container then
            self.HealthBarInstances[plr].Container:Destroy()
        end
        self.HealthBarInstances[plr] = nil
    end
end

function XrayController:UpdateHealthBar(plr)
    local healthData = self.HealthBarInstances[plr]
    if not healthData then return end

    local character = plr.Character
    if not character then
        healthData.Container.Visible = false
        return
    end

    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then
        healthData.Container.Visible = false
        return
    end

    local head = character:FindFirstChild("Head")
    if not head then
        head = character:FindFirstChild("HumanoidRootPart")
        if not head then
            healthData.Container.Visible = false
            return
        end
    end

    local headPos = head.Position + Vector3.new(0, 2.5, 0)
    local screenPos, onScreen = CurrentCamera:WorldToViewportPoint(headPos)

    if screenPos.Z <= 0 or screenPos.X < -200 or screenPos.X > CurrentCamera.ViewportSize.X + 200 or
       screenPos.Y < -200 or screenPos.Y > CurrentCamera.ViewportSize.Y + 200 then
        healthData.Container.Visible = false
        return
    end

    local localPlayer = Players.LocalPlayer
    local localCharacter = localPlayer.Character
    local distance = 0

    if localCharacter and localCharacter:FindFirstChild("HumanoidRootPart") then
        distance = (head.Position - localCharacter.HumanoidRootPart.Position).Magnitude
    end

    local scale = 1
    if distance > self.HealthBarFullScaleDistance then
        if distance >= self.HealthBarMaxDistance then
            scale = self.HealthBarMinScale
        else
            local t = (distance - self.HealthBarFullScaleDistance) / (self.HealthBarMaxDistance - self.HealthBarFullScaleDistance)
            scale = 1 - t * (1 - self.HealthBarMinScale)
        end
    end

    local scaledWidth = math.floor(self.HealthBarWidth * scale)
    local scaledHeight = math.floor(self.HealthBarHeight * scale)
    local scaledOffsetY = math.floor(self.HealthBarOffsetY * scale)

    healthData.Container.Visible = true
    healthData.Container.Position = UDim2.new(0, screenPos.X - scaledWidth / 2, 0, screenPos.Y + scaledOffsetY)
    healthData.Container.Size = UDim2.new(0, scaledWidth, 0, scaledHeight)

    local healthPercent = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
    healthData.Fill.Size = UDim2.new(healthPercent, 0, 1, 0)

    if healthPercent <= 0.3 then
        healthData.Fill.BackgroundColor3 = Color3.fromRGB(180, 30, 30)
    elseif healthPercent <= 0.6 then
        healthData.Fill.BackgroundColor3 = Color3.fromRGB(255, 150, 50)
    else
        healthData.Fill.BackgroundColor3 = self.HealthBarFillColor
    end
end

function XrayController:UpdateAllHealthBars()
    if not self.HealthBarEnabled then return end
    for plr, _ in pairs(self.HealthBarInstances) do
        if plr and plr.Parent then
            self:UpdateHealthBar(plr)
        else
            self:DestroyHealthBar(plr)
        end
    end
end

function XrayController:CreateESPForPlayer(plr)
    if plr == self.LocalPlayer then return end
    
    self:EnsureStorage()
    
    if self.HighlightEnabled then
        local highlight = self:CreateHighlight(plr)
        if highlight and plr.Character then
            highlight.Adornee = plr.Character
        end
    end
    
    if self.NameEnabled then
        self:CreateNameTag(plr)
        if self.BillboardInstances[plr] and plr.Character then
            local head = plr.Character:FindFirstChild("Head") or plr.Character:FindFirstChild("HumanoidRootPart")
            if head then
                self.BillboardInstances[plr].Adornee = head
                self.BillboardInstances[plr].Enabled = true
            end
        end
    end
    
    if self.BoxEnabled then
        self:CreateBoxESP(plr)
    end
    
    if self.HealthBarEnabled then
        self:CreateHealthBar(plr)
    end
    
    if not self.Connections[plr] then
        self.Connections[plr] = {}
    end
    
    if self.Connections[plr].charAdded then
        self.Connections[plr].charAdded:Disconnect()
    end
    if self.Connections[plr].charRemoving then
        self.Connections[plr].charRemoving:Disconnect()
    end
    
    self.Connections[plr].charAdded = plr.CharacterAdded:Connect(function(char)
        wait(0.5)
        
        if self.HighlightEnabled and self.HighlightInstances[plr] then
            self.HighlightInstances[plr].Adornee = char
        end
        
        if self.NameEnabled then
            local head = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
            if head and self.BillboardInstances[plr] then
                self.BillboardInstances[plr].Adornee = head
                self.BillboardInstances[plr].Enabled = true
            end
        end
        
        if self.BoxEnabled then
            if not self.BoxInstances[plr] then
                self:CreateBoxESP(plr)
            else
                self:UpdateBoxESP(plr)
            end
        end
        
        if self.HealthBarEnabled then
            if not self.HealthBarInstances[plr] then
                self:CreateHealthBar(plr)
            end
        end
    end)
    
    self.Connections[plr].charRemoving = plr.CharacterRemoving:Connect(function()
        if self.HighlightInstances[plr] then
            self.HighlightInstances[plr].Adornee = nil
        end
        if self.BillboardInstances[plr] then
            self.BillboardInstances[plr].Enabled = false
        end
        if self.BoxInstances[plr] then
            self.BoxInstances[plr].Frame.Visible = false
        end
        if self.HealthBarInstances[plr] then
            self.HealthBarInstances[plr].Container.Visible = false
        end
    end)
end

function XrayController:UpdateAllESP()
    if self.HighlightEnabled then
        for plr, highlight in pairs(self.HighlightInstances) do
            if plr and plr.Parent and highlight then
                local char = plr.Character
                if char and highlight.Adornee ~= char then
                    highlight.Adornee = char
                end
            end
        end
    end
    
    if self.NameEnabled then
        for plr, billboard in pairs(self.BillboardInstances) do
            if plr and plr.Parent and billboard then
                local char = plr.Character
                if char then
                    local head = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
                    if head and billboard.Adornee ~= head then
                        billboard.Adornee = head
                        billboard.Enabled = true
                    end
                else
                    billboard.Enabled = false
                end
            end
        end
    end
    
    if self.BoxEnabled then
        for plr, boxData in pairs(self.BoxInstances) do
            if plr and plr.Parent then
                self:UpdateBoxESP(plr)
            end
        end
    end
    
    if self.HealthBarEnabled then
        self:UpdateAllHealthBars()
    end
end

function XrayController:CleanupPlayerESP(plr)
    if self.HighlightInstances[plr] then
        self.HighlightInstances[plr]:Destroy()
        self.HighlightInstances[plr] = nil
    end
    
    if self.BillboardInstances[plr] then
        self.BillboardInstances[plr]:Destroy()
        self.BillboardInstances[plr] = nil
    end
    
    if self.BoxInstances[plr] then
        self.BoxInstances[plr].Frame:Destroy()
        self.BoxInstances[plr] = nil
    end
    
    if self.HealthBarInstances[plr] then
        self:DestroyHealthBar(plr)
    end
    
    if self.Connections[plr] then
        for _, conn in pairs(self.Connections[plr]) do
            if conn and typeof(conn) == "RBXScriptConnection" then
                conn:Disconnect()
            end
        end
        self.Connections[plr] = nil
    end
end

