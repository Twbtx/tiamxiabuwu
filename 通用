    local function createRotatingParticles()
        for _, particle in ipairs(rotatingParticles) do
            if particle and particle.instance and particle.instance.Parent then
                particle.instance:Destroy()
            end
        end
        rotatingParticles = {}
        
        local btnAbsPos = onof.AbsolutePosition
        local btnSize = onof.AbsoluteSize
        local centerX = btnAbsPos.X + btnSize.X / 2
        local centerY = btnAbsPos.Y + btnSize.Y / 2
        
        for i = 1, particleCount do
            local angle = (i - 1) * (2 * math.pi / particleCount)
            local particle = Instance.new("ImageLabel")
            particle.Size = UDim2.new(0, 14, 0, 14)
            particle.BackgroundTransparency = 1
            particle.Image = "rbxassetid://104269942650107"
            particle.ImageTransparency = 1
            particle.Visible = true
            particle.Parent = main
            
            local offsetX = math.cos(angle) * particleRadius
            local offsetY = math.sin(angle) * particleRadius
            particle.Position = UDim2.new(0, centerX + offsetX - 7, 0, centerY + offsetY - 7)
            
            rotatingParticles[i] = {
                instance = particle,
                angle = angle
            }
        end
    end

    local function updateRotatingParticles()
        if not nowe then return end
        
        local btnAbsPos = onof.AbsolutePosition
        local btnSize = onof.AbsoluteSize
        local centerX = btnAbsPos.X + btnSize.X / 2
        local centerY = btnAbsPos.Y + btnSize.Y / 2
        
        for _, data in ipairs(rotatingParticles) do
            if data.instance and data.instance.Parent then
                data.angle = data.angle + particleSpeed
                if data.angle > 2 * math.pi then
                    data.angle = data.angle - 2 * math.pi
                end
                local offsetX = math.cos(data.angle) * particleRadius
                local offsetY = math.sin(data.angle) * particleRadius
                data.instance.Position = UDim2.new(0, centerX + offsetX - 7, 0, centerY + offsetY - 7)
            end
        end
    end

    local function hideParticlesInstant()
        if particleConnection then
            particleConnection:Disconnect()
            particleConnection = nil
        end
        for _, data in ipairs(rotatingParticles) do
            if data.instance and data.instance.Parent then
                data.instance.ImageTransparency = 1
            end
        end
        particleRunning = false
    end

    local function showParticlesInstant()
        if not nowe then return end
        if particleConnection then return end
        
        if #rotatingParticles == 0 then
            createRotatingParticles()
        end
        
        for _, data in ipairs(rotatingParticles) do
            if data.instance and data.instance.Parent then
                data.instance.ImageTransparency = 0
            end
        end
        
