local function addTextStroke(obj)
    if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
        obj.TextStrokeTransparency = 0
        obj.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    end
end

local function addStrokeToAllText(container)
    if not container then return end
    for _, obj in ipairs(container:GetDescendants()) do
        addTextStroke(obj)
    end
end

local function setupStrokeWatcher()
    local function onDescendantAdded(descendant)
        addTextStroke(descendant)
    end
    
    local coreGui = game:GetService("CoreGui")
    coreGui.DescendantAdded:Connect(onDescendantAdded)
    
    local playerGui = game.Players.LocalPlayer:WaitForChild("PlayerGui")
    playerGui.DescendantAdded:Connect(onDescendantAdded)
    
    addStrokeToAllText(coreGui)
    addStrokeToAllText(playerGui)
end

