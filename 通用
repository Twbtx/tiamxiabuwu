        for i, existingRoot in ipairs(activeNotifications) do
            if existingRoot == notifRoot then
                table.remove(activeNotifications, i)
                break
            end
        end

        repositionAllNotifications(nil)

        local currentPos = notifRoot.Position
        local currentXOffset = currentPos.X.Offset
        local currentYOffset = currentPos.Y.Offset
        local slideOutXOffset = currentXOffset + NOTIF_WIDTH + 100
        local targetPosition = UDim2.new(1, slideOutXOffset, 1, currentYOffset)

        local slideTween = tweenToPosition(notifRoot, targetPosition, ANIMATION_DURATION)
        slideTween.Completed:Connect(function()
            if borderAnimations[notifRoot] then
                borderAnimations[notifRoot]()
                borderAnimations[notifRoot] = nil
            end
            notifRoot:Destroy()
        end)
