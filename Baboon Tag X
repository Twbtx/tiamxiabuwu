local infectedColor = Color3.fromRGB(255, 89, 89)

local function getPlayerNameColor(character)
    local nametag = character:FindFirstChild("Nametag")
    if nametag then
        local playerName = nametag:FindFirstChild("PlayerName")
        if playerName and playerName:IsA("TextLabel") then
            return playerName.TextColor3
        end
    end
    return nil
end

local function isInfected(character)
    local color = getPlayerNameColor(character)
    return color == infectedColor
end

local randomTeleportActive = false
local randomTeleportConn = nil
local randomTeleportRunning = false

local function randomTeleportToNonInfected()
    if not randomTeleportActive then return end
    if randomTeleportRunning then return end
    randomTeleportRunning = true

    local localPlayer = game.Players.LocalPlayer
    local localChar = localPlayer.Character
    if not localChar or not localChar:FindFirstChild("HumanoidRootPart") then
        randomTeleportRunning = false
        return
    end

    if not isInfected(localChar) then
        randomTeleportRunning = false
        return
    end

    local nonInfectedList = {}
    for _, plr in ipairs(game.Players:GetPlayers()) do
        if plr ~= localPlayer then
            local char = plr.Character
            if char and char.Parent then
                if not isInfected(char) then
                    table.insert(nonInfectedList, plr)
                end
            end
        end
    end

    if #nonInfectedList == 0 then
        randomTeleportRunning = false
        return
    end

    local randomIndex = math.random(1, #nonInfectedList)
    local target = nonInfectedList[randomIndex]
    local targetChar = target.Character
    if targetChar and targetChar:FindFirstChild("HumanoidRootPart") then
        local hrp = localChar.HumanoidRootPart
        hrp.CFrame = targetChar.HumanoidRootPart.CFrame
        WindUI:Notify({ Title = "传送", Content = "传送到未感染者 " .. target.Name, Duration = 1 })
    end

    randomTeleportRunning = false
end

TabPlayer:Toggle({
    Title = "随机传送至未感染者（仅自己感染时）",
    Value = false,
    Callback = function(state)
        randomTeleportActive = state
        if state then
            if randomTeleportConn then randomTeleportConn:Disconnect() end
            randomTeleportConn = game:GetService("RunService").Heartbeat:Connect(function()
                if randomTeleportActive and not randomTeleportRunning then
                    randomTeleportToNonInfected()
                    task.wait(0.5)
                end
            end)
        else
            if randomTeleportConn then
                randomTeleportConn:Disconnect()
                randomTeleportConn = nil
            end
            randomTeleportRunning = false
        end
    end
})

local loopConn = nil
local spheres = {}

local function addSphere(player)
    local char = player.Character
    if not char then return end
    if spheres[player] then return end

    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local sphere = Instance.new("Part")
    sphere.Name = "InfectionSphere"
    sphere.Shape = Enum.PartType.Ball
    sphere.Size = Vector3.new(35, 35, 35)
    sphere.Transparency = 0.25
    sphere.CanCollide = true
    sphere.Massless = true
    sphere.Anchored = false
    sphere.CastShadow = false
    sphere.CanQuery = false
    sphere.Material = Enum.Material.SmoothPlastic
    sphere.CFrame = hrp.CFrame
    sphere.Parent = char

    local weld = Instance.new("Weld")
    weld.Part0 = hrp
    weld.Part1 = sphere
    weld.C0 = hrp.CFrame:Inverse() * sphere.CFrame
    weld.Parent = sphere

    spheres[player] = sphere
end

local function removeSphere(player)
    local sphere = spheres[player]
    if sphere then
        sphere:Destroy()
        spheres[player] = nil
    end
end

local function updateProtection()
    local localPlayer = game.Players.LocalPlayer
    for _, plr in ipairs(game.Players:GetPlayers()) do
        if plr ~= localPlayer then
            local char = plr.Character
            if char and char.Parent then
                if isInfected(char) then
                    addSphere(plr)
                else
                    removeSphere(plr)
                end
            else
                removeSphere(plr)
            end
        end
    end
end

TabProtect:Toggle({
    Title = "开启防护(给感染者装一个球)",
    Value = false,
    Callback = function(state)
        if state then
            updateProtection()
            loopConn = game:GetService("RunService").Heartbeat:Connect(function()
                updateProtection()
                task.wait(0.1)
            end)
        else
            if loopConn then
                loopConn:Disconnect()
                loopConn = nil
            end
            for _, sphere in pairs(spheres) do
                if sphere then sphere:Destroy() end
            end
            spheres = {}
        end
    end
})

