local NothingLibrary = loadstring(game:HttpGetAsync('https://raw.githubusercontent.com/3345-c-a-t-s-u-s/NOTHING/main/source.lua'))();
local Windows = NothingLibrary.new({
    Title = "Guts & Blackpowder V1.1.0",
    Description = "最大帮助者:柳叶",
    Keybind = Enum.KeyCode.LeftControl,
    Logo = 'rbxassetid://18898582662'
})
local _S = {}
_S.lp = game:GetService("Players").LocalPlayer
_S.camera = workspace.CurrentCamera
_S.pgui = _S.lp:WaitForChild("PlayerGui")
_S.ControlModule = require(_S.lp.PlayerScripts:WaitForChild("PlayerModule")):GetControls()
_S.RunService = game:GetService("RunService")
_S.UserInputService = game:GetService("UserInputService")
_S.Workspace = workspace
_S.ReplicatedStorage = game:GetService("ReplicatedStorage")
_S.HttpService = game:GetService("HttpService")
_S.TweenService = game:GetService("TweenService")
_S.Config = {
    speedEnabled = true, playerSpeed = 16,
    jumpModEnabled = false, jumpHeight = 60, antiFallEnabled = false,
    autoFaceEnabled = false, autoFaceRange = 17, skipBarrel = false,
    noSlowActive = false, noFallActive = false, backpackAlwaysOn = false, brightEnabled = false, autoDoorEnabled = false,
    autoDig = false, autoLog = false, autoPlace = false, autoRepairBridge = false, autoCollect = false,
    flySpeed_orig = 45, flySpeed_new = 45, isWallhack_new = false,
    auraEnabled = false, killWaveEnabled = false, killAnimEnabled = false, attackBarrelEnabled = false,
    espEnabled = { Axe = false, Eye = false, Sword = false, Barrel = false, FTorso = false },
    hammerAuto = false, engineerRecycle = false, engineerElbow = false, autoElbow = false,
    officerAutoJump = false, autoShoot = false, autoReload = false, shootRange = 200, playerCheckRange = 10,
    silentAim = false, silentAimMode = "FOV", silentAimFOV = 150, silentAimPart = "Body",
    silentAimTypes = { Axe = false, Eye = false, Sword = false, Barrel = false, FTorso = false },
    pvpAimEnabled = false, pvpAimMode = "FOV", pvpAimFOV = 150, pvpAimPart = "Head", pvpAllowFriends = true, pvpHighDamageFirst = true,
    noSpread = false, showTrajectory = false, healCanMove = false, noBloodSplatter = false,
    simpleZombieAI = false, fixFireLag = false, preventBarrelHit = false, multiTargetCount = 2,
    attackInterval = 0.005,
    attackRange = 35,
    silentScanInterval = 0.5,
    showSpeedValue = false,
    rammingEnabled = false,
    zombieCollisionRemoval = false,
    standWalkEnabled = false,
    clickTeleportEnabled = false,
    autoJumpEnabled = false,
    autoJumpHeight = 60
}
_S.isFlying_orig = false
_S.isFlying_new = false

-- ==================== 原有功能（大部分不变） ====================
do
    local lastJump = 0
    local cooldown = 0.6
    local fallStartY = nil
    local antiFallConn = nil
    local function updateWalkSpeed()
        local char = _S.lp.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        if not _S.Config.speedEnabled then hum.WalkSpeed = 16 else hum.WalkSpeed = _S.Config.playerSpeed end
    end
    _S.updateWalkSpeed = updateWalkSpeed
    local function startAntiFall()
        if antiFallConn then antiFallConn:Disconnect() end
        antiFallConn = _S.RunService.Heartbeat:Connect(function()
            if not _S.Config.antiFallEnabled then return end
            local char = _S.lp.Character
            if not char then fallStartY = nil; return end
            local root = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not root or not hum then return end
            local y = root.Position.Y
            local vy = root.Velocity.Y
            if vy < -0.1 then
                if not fallStartY then fallStartY = y
                elseif fallStartY - y >= 15 then
                    hum:ChangeState(Enum.HumanoidStateType.Jumping)
                    root.Velocity = Vector3.new(root.Velocity.X, 25, root.Velocity.Z)
                    fallStartY = nil
                end
            else fallStartY = nil end
        end)
    end
    _S.startAntiFall = startAntiFall
    local function stopAntiFall()
        if antiFallConn then antiFallConn:Disconnect(); antiFallConn = nil end
        fallStartY = nil
    end
    _S.stopAntiFall = stopAntiFall
    _S.UserInputService.JumpRequest:Connect(function()
        if not _S.Config.jumpModEnabled then return end
        local char = _S.lp.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if hum and root and tick() - lastJump >= cooldown then
            lastJump = tick()
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
            root.Velocity = Vector3.new(root.Velocity.X, _S.Config.jumpHeight, root.Velocity.Z)
        end
    end)
    _S.RunService.RenderStepped:Connect(function()
        if not _S.Config.jumpModEnabled then return end
        local char = _S.lp.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if hum and root then
            local us = _S.lp:FindFirstChild("UserStates")
            if us then for _, s in pairs({"BrokenLegs","Grabbed","Pin"}) do if us:FindFirstChild(s) then us[s].Value = false end end end
            local ani = char:FindFirstChild("Animate")
            if ani then ani.Parent = nil end
            if root.Velocity.Y < -5 and not _S.UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                hum:ChangeState(Enum.HumanoidStateType.Climbing)
            end
        end
    end)
end

do
    local autoFaceThread = nil
    local function getNearestZombie()
        local char = _S.lp.Character
        if not char then return nil end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return nil end
        local best, bestDist = nil, math.huge
        local zfolder = _S.Workspace:FindFirstChild("Zombies")
        if zfolder then
            for _, z in pairs(zfolder:GetChildren()) do
                if z:IsA("Model") and z:FindFirstChild("HumanoidRootPart") then
                    if _S.Config.skipBarrel and z:GetAttribute("Type") == "Barrel" then continue end
                    local state = z:FindFirstChild("State")
                    if state and state.Value == "Spawn" then continue end
                    local dist = (z.HumanoidRootPart.Position - root.Position).Magnitude
                    if dist <= _S.Config.autoFaceRange and dist < bestDist then bestDist = dist; best = z end
                end
            end
        end
        return best
    end
    local function faceZombie(z)
        if not z or not z:FindFirstChild("HumanoidRootPart") then return end
        local char = _S.lp.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not root or not hum then return end
        local old = hum.AutoRotate
        hum.AutoRotate = false
        root.CFrame = CFrame.lookAt(root.Position, Vector3.new(z.HumanoidRootPart.Position.X, root.Position.Y, z.HumanoidRootPart.Position.Z))
        hum.AutoRotate = old
    end
    local function loop()
        while _S.Config.autoFaceEnabled do
            local z = getNearestZombie()
            if z then faceZombie(z) end
            task.wait(0.1)
        end
    end
    _S.startAutoFace = function()
        if autoFaceThread then task.cancel(autoFaceThread) end
        if _S.Config.autoFaceEnabled then autoFaceThread = task.spawn(loop) end
    end
    _S.stopAutoFace = function()
        if autoFaceThread then task.cancel(autoFaceThread); autoFaceThread = nil end
    end
end

do
    local noSlowConn = nil
    local noFallThread = nil
    local backConn = nil
    local origLight = nil
    local doorThread = nil
    local doorProcessing = {}
    _S.setupNoSlow = function()
        if not _S.lp.Character then return end
        local hum = _S.lp.Character:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        if noSlowConn then noSlowConn:Disconnect() end
        noSlowConn = hum:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
            if _S.Config.noSlowActive and hum.WalkSpeed < 16 then hum.WalkSpeed = 16 end
        end)
        if _S.Config.noSlowActive and hum.WalkSpeed < 16 then hum.WalkSpeed = 16 end
    end
    _S.preventFallDamage = function()
        while _S.Config.noFallActive do
            if _S.lp.Character then
                local h = _S.lp.Character:FindFirstChild("Health")
                if h then local f = h:FindFirstChild("ForceSelfDamage"); if f then f:FireServer(0) end end
            end
            task.wait(1)
        end
    end
    _S.autoDoorLoop = function()
        while _S.Config.autoDoorEnabled do
            local char = _S.lp.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if root then
                for _, item in pairs(_S.Workspace:GetDescendants()) do
                    if item.Name == "Main" and item:IsA("Model") then
                        if (root.Position - item:GetModelCFrame().Position).Magnitude <= 23 then
                            local open = item:GetAttribute("Open")
                            if open == nil then pcall(function() open = item.Open end) end
                            if open == false then
                                local mp = item:FindFirstChild("Main")
                                local remote = mp and mp:FindFirstChild("Interact")
                                if remote and remote:IsA("RemoteEvent") and not doorProcessing[item] then
                                    doorProcessing[item] = true
                                    task.spawn(function() remote:FireServer(); task.wait(0.5); doorProcessing[item] = nil end)
                                end
                            end
                        end
                    end
                end
            end
            task.wait(0.1)
        end
    end
end

do
    local digPaths = {"Vardohus Fortress/Modes/Objective/DoorSnow/Diggable","Vardohus Fortress/Modes/Objective/Diggable","OLD Vardohus Fortress/Modes/Objective/DigSnow/Diggable"}
    local function getDigTool()
        local char = _S.lp.Character
        if not char then return nil end
        for _, t in pairs(char:GetChildren()) do if (t.Name=="Shovel" or t.Name=="Spade") and t:FindFirstChild("RemoteEvent") then return t end end
        for _, t in pairs(_S.lp.Backpack:GetChildren()) do if (t.Name=="Shovel" or t.Name=="Spade") and t:FindFirstChild("RemoteEvent") then return t end end
        return nil
    end
    local function findDig()
        for _, p in ipairs(digPaths) do
            local cur = _S.Workspace
            for seg in string.gmatch(p, "[^/]+") do cur = cur:FindFirstChild(seg); if not cur then break end end
            if cur then return cur end
        end
        return nil
    end
    _S.autoDigLoop = function()
        while _S.Config.autoDig do
            local dig = findDig()
            local tool = getDigTool()
            if dig and tool then
                if tool.Parent ~= _S.lp.Character then tool.Parent = _S.lp.Character; task.wait(0.2) end
                local re = tool:FindFirstChild("RemoteEvent")
                if re then re:FireServer("Dig", dig, dig.Position) end
            end
            task.wait(0.05)
        end
    end
    _S.autoLogLoop = function()
        while _S.Config.autoLog do
            local remote = _S.Workspace:FindFirstChild("Berezina") and _S.Workspace.Berezina:FindFirstChild("Modes") and _S.Workspace.Berezina.Modes:FindFirstChild("Holdout") and _S.Workspace.Berezina.Modes.Holdout:FindFirstChild("Log") and _S.Workspace.Berezina.Modes.Holdout.Log:FindFirstChild("Log") and _S.Workspace.Berezina.Modes.Holdout.Log.Log:FindFirstChild("Interact")
            if remote then pcall(function() remote:FireServer() end) end
            task.wait(0.05)
        end
    end
    _S.autoPlaceLoop = function()
        while _S.Config.autoPlace do
            for _, p in pairs(_S.Workspace:GetDescendants()) do if p:IsA("ProximityPrompt") and p.Name=="PlaceLogProximityPrompt" then pcall(function() fireproximityprompt(p) end) end end
            task.wait(0.1)
        end
    end
    _S.doRepairBridge = function()
        local char = _S.lp.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local bridge = _S.Workspace:FindFirstChild("Berezina") and _S.Workspace.Berezina:FindFirstChild("Modes") and _S.Workspace.Berezina.Modes:FindFirstChild("Holdout") and _S.Workspace.Berezina.Modes.Holdout:FindFirstChild("Bridge")
        if not bridge then return end
        local nearest, bestDist = nil, math.huge
        for _, sec in pairs(bridge:GetChildren()) do
            local posts = sec:FindFirstChild("Posts")
            if posts then for _, part in pairs(posts:GetChildren()) do if part:IsA("BasePart") and part:FindFirstChild("ConstructHealth") then local d = (part.Position - root.Position).Magnitude; if d<bestDist then bestDist=d; nearest=part.ConstructHealth end end end end
            local beam = sec:FindFirstChild("Beam")
            if beam and beam:FindFirstChild("ConstructHealth") then local d = (beam.Position - root.Position).Magnitude; if d<bestDist then bestDist=d; nearest=beam.ConstructHealth end end
            for _, j in pairs(sec:GetChildren()) do if j.Name=="Joists" and j:FindFirstChild("ConstructHealth") then local d = (j.Position - root.Position).Magnitude; if d<bestDist then bestDist=d; nearest=j.ConstructHealth end end end
        end
        if not nearest then return end
        local hammer = _S.lp.Backpack:FindFirstChild("Hammer") or _S.lp.Backpack:FindFirstChild("Claw Hammer")
        if hammer and hammer:FindFirstChild("RemoteEvent") then hammer.RemoteEvent:FireServer("Repair", nearest) end
    end
    local collectPrompts = {}
    _S.setupAutoCollect = function()
        for _, d in pairs(_S.Workspace:GetDescendants()) do if d:IsA("ProximityPrompt") then collectPrompts[d]=true end end
        local conn = _S.Workspace.DescendantAdded:Connect(function(d) if d:IsA("ProximityPrompt") then collectPrompts[d]=true end end)
        local heartbeat = _S.RunService.Heartbeat:Connect(function()
            if not _S.Config.autoCollect then return end
            local hrp = _S.lp.Character and _S.lp.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            for p,_ in pairs(collectPrompts) do
                if p and p.Parent and p:IsA("ProximityPrompt") and p.Enabled then
                    local part = p.Parent
                    if part:IsA("BasePart") and (part.Position - hrp.Position).Magnitude <= p.MaxActivationDistance then
                        fireproximityprompt(p)
                    end
                else collectPrompts[p]=nil end
            end
        end)
        _S.collectAddedConn = conn
        _S.collectHeartbeat = heartbeat
    end
end

do
    local bv_orig, bg_orig, animCache_orig, hrp_orig, hum_orig
    local function clearFly_orig()
        if animCache_orig and _S.lp.Character then animCache_orig.Parent = _S.lp.Character end
        if bv_orig then bv_orig:Destroy() end
        if bg_orig then bg_orig:Destroy() end
        bv_orig,bg_orig = nil,nil
        if hum_orig and hum_orig.Parent then hum_orig:ChangeState(Enum.HumanoidStateType.Running) end
    end
    local function ensurePhysics_orig(hrp)
        if hrp:FindFirstChild("LeipzigBV_orig") then hrp.LeipzigBV_orig:Destroy() end
        if hrp:FindFirstChild("LeipzigBG_orig") then hrp.LeipzigBG_orig:Destroy() end
        bv_orig = Instance.new("BodyVelocity", hrp)
        bv_orig.Name = "LeipzigBV_orig"
        bv_orig.MaxForce = Vector3.new(1e6,1e6,1e6)
        bg_orig = Instance.new("BodyGyro", hrp)
        bg_orig.Name = "LeipzigBG_orig"
        bg_orig.MaxTorque = Vector3.new(math.huge,math.huge,math.huge)
        bg_orig.P = 10000; bg_orig.D = 50
    end
    _S.startFly_orig = function()
        if _S.isFlying_orig then return end
        local char = _S.lp.Character
        if not char then return end
        hrp_orig = char:WaitForChild("HumanoidRootPart")
        hum_orig = char:WaitForChild("Humanoid")
        local ani = char:FindFirstChild("Animate")
        if ani then animCache_orig = ani; ani.Parent = nil end
        ensurePhysics_orig(hrp_orig)
        _S.isFlying_orig = true
        task.spawn(function()
            while _S.isFlying_orig and char.Parent do
                local mv = _S.ControlModule:GetMoveVector()
                local cf = _S.camera.CFrame
                local dir = (cf.LookVector * -mv.Z) + (cf.RightVector * mv.X)
                if mv.Magnitude > 0 then bv_orig.Velocity = dir.Unit * _S.Config.flySpeed_orig else bv_orig.Velocity = Vector3.new(0,0.01,0) end
                hum_orig:ChangeState(Enum.HumanoidStateType.Climbing)
                _S.RunService.RenderStepped:Wait()
            end
            clearFly_orig()
        end)
    end
    _S.stopFly_orig = function()
        if not _S.isFlying_orig then return end
        _S.isFlying_orig = false
        clearFly_orig()
    end
    local bv_new, animCache_new, hrp_new, hum_new
    local function clearFly_new()
        if animCache_new and _S.lp.Character then animCache_new.Parent = _S.lp.Character end
        if bv_new then bv_new:Destroy() end
        bv_new = nil
        if hum_new and hum_new.Parent then hum_new:ChangeState(Enum.HumanoidStateType.Running) end
    end
    _S.startFly_new = function()
        if _S.isFlying_new then return end
        local char = _S.lp.Character
        if not char then return end
        hrp_new = char:WaitForChild("HumanoidRootPart")
        hum_new = char:WaitForChild("Humanoid")
        local ani = char:FindFirstChild("Animate")
        if ani then animCache_new = ani; ani.Parent = nil end
        if hrp_new:FindFirstChild("LeipzigBV_new") then hrp_new.LeipzigBV_new:Destroy() end
        bv_new = Instance.new("BodyVelocity", hrp_new)
        bv_new.Name = "LeipzigBV_new"
        bv_new.MaxForce = Vector3.new(1e6,1e6,1e6)
        _S.isFlying_new = true
        task.spawn(function()
            while _S.isFlying_new and char.Parent do
                local mv = _S.ControlModule:GetMoveVector()
                local cf = _S.camera.CFrame
                local dir = (cf.LookVector * -mv.Z) + (cf.RightVector * mv.X)
                if mv.Magnitude > 0 then bv_new.Velocity = dir.Unit * _S.Config.flySpeed_new else bv_new.Velocity = Vector3.new(0,0.01,0) end
                hum_new:ChangeState(Enum.HumanoidStateType.Climbing)
                if _S.Config.isWallhack_new and _S.lp.Character then
                    for _, p in pairs(_S.lp.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end
                end
                _S.RunService.RenderStepped:Wait()
            end
            clearFly_new()
        end)
    end
    _S.stopFly_new = function()
        if not _S.isFlying_new then return end
        _S.isFlying_new = false
        clearFly_new()
    end
end

do
    local function getPurchaseEvent()
        local rs = _S.ReplicatedStorage
        local events = rs:FindFirstChild("Events")
        if not events then return nil end
        local customize = events:FindFirstChild("Customize")
        if not customize then return nil end
        return customize:FindFirstChild("PurchaseEvent")
    end
    local function getEquipEvent()
        local rs = _S.ReplicatedStorage
        local events = rs:FindFirstChild("Events")
        if not events then return nil end
        return events:FindFirstChild("EquipWeapon")
    end
    _S.getPurchaseEvent = getPurchaseEvent
    _S.getEquipEvent = getEquipEvent
end

do
    local attackThread = nil
    local attackIdx = 1
    local killWaveThread = nil
    local killAnimConn = nil
    local WAVE_INTERVAL = 0.6
    local ANIM_CONFIGS = {
        {id="rbxassetid://12591932646",delay=0.2},{id="rbxassetid://12591945044",delay=0.27},
        {id="rbxassetid://12591944118",delay=0.4},{id="rbxassetid://12591941810",delay=0.2},
        {id="rbxassetid://12638403582",delay=0.65},{id="rbxassetid://114385794993502",delay=0.65},
        {id="rbxassetid://12638409326",delay=0.74}
    }
    local function getMelee()
        local char = _S.lp.Character
        if not char then return nil end
        for _, t in pairs(char:GetChildren()) do if t:IsA("Tool") and t:GetAttribute("Melee") then return t end end
        return nil
    end
    local function distanceToZombie(z)
        local char = _S.lp.Character
        if not char then return math.huge end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return math.huge end
        local zr = z:FindFirstChild("HumanoidRootPart")
        if not zr then return math.huge end
        return (zr.Position - root.Position).Magnitude
    end
    local function attackZombie(z, weapon)
        if _S.Config.preventBarrelHit and z:GetAttribute("Type")=="Barrel" then return end
if not weapon or distanceToZombie(z) > _S.Config.attackRange then return end
        local remote = weapon:FindFirstChild("RemoteEvent")
        local head = z:FindFirstChild("Head")
        if not remote or not head then return end
        if weapon.Name=="Axe" and z:FindFirstChild("State") and z.State.Value~="Stunned" then
            remote:FireServer("BraceBlock"); remote:FireServer("StopBraceBlock"); remote:FireServer("FeedbackStun",z,z.HumanoidRootPart.Position)
        end
        remote:FireServer("Swing","Side")
        remote:FireServer("HitZombie",z,head.Position,true)
    end
    local function attackLoop()
        while _S.Config.auraEnabled do
            local char = _S.lp.Character
            if char then
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health>0 then
                    local weapon = getMelee()
                    if weapon then
                        local zombies = {}
                        local zf = _S.Workspace:FindFirstChild("Zombies")
                        if zf then for _,z in pairs(zf:GetChildren()) do
                            if z:IsA("Model") and z:FindFirstChild("HumanoidRootPart") then
                                if not _S.Config.attackBarrelEnabled and z:GetAttribute("Type")=="Barrel" then continue end
                                local st = z:FindFirstChild("State")
                                if st and st.Value=="Spawn" then continue end
                                if distanceToZombie(z) <= _S.Config.attackRange then table.insert(zombies,z) end
                            end
                        end end
                        local cnt = #zombies
                        if cnt>0 then
                            if attackIdx>cnt then attackIdx=1 end
                            local toAttack = math.min(_S.Config.multiTargetCount, cnt)
                            for i=1,toAttack do
                                local z = zombies[attackIdx]
                                if z then attackZombie(z,weapon) end
                                attackIdx = attackIdx+1
                                if attackIdx>cnt then attackIdx=1 end
                            end
                        else attackIdx=1 end
                    end
                end
            end
            task.wait(_S.Config.attackInterval)
        end
    end
    _S.startAura = function()
        if attackThread then return end
        _S.Config.auraEnabled = true
        attackIdx = 1
        attackThread = task.spawn(attackLoop)
    end
    _S.stopAura = function()
        _S.Config.auraEnabled = false
        if attackThread then task.cancel(attackThread); attackThread=nil end
    end
    local function waveLoop()
        while _S.Config.killWaveEnabled do
            local char = _S.lp.Character
            if char then
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health>0 then
                    local weapon = getMelee()
                    if weapon then
                        local zombies = {}
                        local zf = _S.Workspace:FindFirstChild("Zombies")
                        if zf then for _,z in pairs(zf:GetChildren()) do
                            if z:IsA("Model") and z:FindFirstChild("HumanoidRootPart") then
                                if not _S.Config.attackBarrelEnabled and z:GetAttribute("Type")=="Barrel" then continue end
                                local st = z:FindFirstChild("State")
                                if st and st.Value=="Spawn" then continue end
                                if distanceToZombie(z) <= _S.Config.attackRange then table.insert(zombies,z) end
                            end
                        end end
                        for i=1,math.min(4,#zombies) do attackZombie(zombies[i],weapon) end
                    end
                end
            end
            task.wait(WAVE_INTERVAL)
        end
    end
    _S.startWaveMode = function()
        if killWaveThread then task.cancel(killWaveThread) end
        if _S.Config.killWaveEnabled then killWaveThread = task.spawn(waveLoop) end
    end
    local function onAnimPlayed(track)
        if not _S.Config.killAnimEnabled then return end
        local aid = track.Animation.AnimationId
        for _,cfg in ipairs(ANIM_CONFIGS) do
            if aid == cfg.id then
                task.delay(cfg.delay, function()
                    if _S.Config.killAnimEnabled then
                        local char = _S.lp.Character
                        if not char then return end
                        local hum = char:FindFirstChildOfClass("Humanoid")
                        if not hum or hum.Health<=0 then return end
                        local weapon = getMelee()
                        if not weapon then return end
                        local zombies = {}
                        local zf = _S.Workspace:FindFirstChild("Zombies")
                        if zf then for _,z in pairs(zf:GetChildren()) do
                            if z:IsA("Model") and z:FindFirstChild("HumanoidRootPart") then
                                if not _S.Config.attackBarrelEnabled and z:GetAttribute("Type")=="Barrel" then continue end
                                local st = z:FindFirstChild("State")
                                if st and st.Value=="Spawn" then continue end
                                if distanceToZombie(z) <= 30 then table.insert(zombies,z) end
                            end
                        end end
                        for _,z in ipairs(zombies) do attackZombie(z,weapon) end
                    end
                end)
                break
            end
        end
    end
    _S.updateKillAnimConn = function()
        if killAnimConn then killAnimConn:Disconnect(); killAnimConn=nil end
        if not _S.Config.killAnimEnabled then return end
        local char = _S.lp.Character
        if not char then _S.lp.CharacterAdded:Connect(function() task.wait(1); _S.updateKillAnimConn() end) return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then killAnimConn = hum.AnimationPlayed:Connect(onAnimPlayed) end
    end
end

do
    local zombieTags = {}
    local espConn = nil
    local types = {Axe={name="斧头僵尸",color=Color3.fromRGB(180,0,250),size=UDim2.new(0,120,0,30),prio=1},
    Eye={name="红眼",color=Color3.fromRGB(255,50,50),size=UDim2.new(0,100,0,30),prio=2},
    Sword={name="胸甲骑兵",color=Color3.fromRGB(255,0,255),size=UDim2.new(0,100,0,30),prio=2},
    Barrel={name="自爆",color=Color3.fromRGB(250,250,0),size=UDim2.new(0,120,0,30),prio=3},
    FTorso={name="提灯人",color=Color3.fromRGB(255,120,0),size=UDim2.new(0,120,0,30),prio=4}}
    local function findZombies()
        local list = {}
        local cam = _S.Workspace:FindFirstChild("Camera")
        if cam then for _,m in pairs(cam:GetDescendants()) do if m:IsA("Model") and m.Name:find("Zombie") then table.insert(list,m) end end end
        return list
    end
    local function getConfig(z)
        local best,bestPrio = nil,math.huge
        for k,cfg in pairs(types) do if z:FindFirstChild(k) and cfg.prio<bestPrio then bestPrio=cfg.prio; best=cfg end end
        return best
    end
    local function createTag(z,cfg)
        if zombieTags[z] then zombieTags[z]:Destroy() end
        local part = z.PrimaryPart or z:FindFirstChild("Head") or z:FindFirstChild("HumanoidRootPart")
        if not part then return end
        local tag = Instance.new("BillboardGui")
        tag.Size = cfg.size
        tag.StudsOffset = Vector3.new(0,2.5,0)
        tag.AlwaysOnTop = true
        tag.Adornee = part
        tag.Parent = z
        local lbl = Instance.new("TextLabel",tag)
        lbl.Size = UDim2.new(1,0,1,0)
        lbl.BackgroundTransparency = 1
        lbl.Text = cfg.name
        lbl.TextColor3 = cfg.color
        lbl.Font = Enum.Font.GothamBold
        lbl.TextSize = 14
        zombieTags[z] = tag
    end
    local function updateESP()
        for z,tag in pairs(zombieTags) do if not z.Parent then tag:Destroy(); zombieTags[z]=nil end end
        local zombies = findZombies()
        for _,z in pairs(zombies) do
            local cfg = getConfig(z)
            if cfg and _S.Config.espEnabled[cfg.name:gsub("僵尸","")] then
                if not zombieTags[z] then createTag(z,cfg) end
            elseif zombieTags[z] then zombieTags[z]:Destroy(); zombieTags[z]=nil end
        end
    end
    _S.startESPUpdate = function()
        if espConn then espConn:Disconnect() end
        local any = false
        for _,v in pairs(_S.Config.espEnabled) do if v then any=true; break end end
        if any then
            espConn = _S.RunService.Heartbeat:Connect(function() if tick()%1<0.016 then updateESP() end end)
        else
            for _,t in pairs(zombieTags) do if t then t:Destroy() end end
            zombieTags = {}
        end
    end
end

do
    local hammerThread = nil
    local engineerAnimConn = nil
    local elbowConn = nil
    local lastElbow = 0
    local officerJumpConn = nil
    local shootThread = nil
    local gunNames = {"Musket","Carbine","Rifle","Pistol","Blunderbuss","Air Rifle","Horse Artillery Pistol","Nock Gun","Navy Pistol","Brass Pistol","Double Barrel Pistol","Flintlock Pistol","Model 29","Old Blunderbuss","Needle Gun","Shotgun","Bolt Rifle","Officer Pistol","Heavy Pistol","Light Dragoon Pistol"}
    local function isGun(t) if not t then return false end for _,n in pairs(gunNames) do if t.Name==n then return true end end return false end
    local function getShots(tool) return (tool:FindFirstChild("ShotsLoaded") and tool.ShotsLoaded.Value) or 0 end
    local function findRemote(tool) return tool:FindFirstChild("RemoteEvent") or (_S.Workspace:FindFirstChild("Players") and _S.Workspace.Players:FindFirstChild(_S.lp.Name) and _S.Workspace.Players[_S.lp.Name]:FindFirstChild(tool.Name) and _S.Workspace.Players[_S.lp.Name][tool.Name]:FindFirstChild("RemoteEvent")) end
    local function tryReload(tool) if _S.Config.autoReload and isGun(tool) and getShots(tool)==0 then local r=findRemote(tool); if r then pcall(function() r:FireServer("Reload") end) end end end
    _S.startHammer = function()
        if hammerThread then return end
        _S.Config.hammerAuto = true
        hammerThread = task.spawn(function()
            while _S.Config.hammerAuto do
                local char = _S.lp.Character
                if char then for _,t in pairs(char:GetChildren()) do if t:IsA("Tool") and (t.Name:lower():find("hammer") or t.Name:lower():find("锤")) then
                    local btn = _S.pgui:FindFirstChild("AttackButton",true)
                    if btn and btn:IsA("TextButton") then btn:Click() else
                        local vm = game:GetService("VirtualInputManager")
                        local sz = _S.camera.ViewportSize
                        vm:SendMouseButtonEvent(sz.X*0.95, sz.Y*0.95, 0, true, nil, 1)
                        task.wait(0.01)
                        vm:SendMouseButtonEvent(sz.X*0.95, sz.Y*0.95, 0, false, nil, 1)
                    end
                end end end
                task.wait(0.5)
            end
        end)
    end
    _S.stopHammer = function() _S.Config.hammerAuto=false; if hammerThread then task.cancel(hammerThread); hammerThread=nil end end
    local function recycleAxe()
        if not _S.Config.engineerRecycle then return end
        local char = _S.lp.Character
        if not char then return end
        local tool = char:FindFirstChildOfClass("Tool")
        if tool and (tool.Name:lower():find("axe") or tool.Name:lower():find("斧")) then
            tool.Parent = _S.lp.Backpack
            task.wait(0.1)
            if _S.Config.engineerRecycle and tool.Parent==_S.lp.Backpack then tool.Parent = char end
        end
    end
    local function stunAround()
        if not _S.Config.engineerElbow then return end
        local char = _S.lp.Character
        if not char then return end
        local tool = char:FindFirstChildOfClass("Tool")
        if not tool or not (tool.Name:lower():find("axe") or tool.Name:lower():find("斧")) then return end
        local remote = tool:FindFirstChild("RemoteEvent")
        if not remote then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local zf = _S.Workspace:FindFirstChild("Zombies")
        if zf then for _,z in pairs(zf:GetChildren()) do if z:IsA("Model") and z:FindFirstChild("HumanoidRootPart") and not z:GetAttribute("Type")=="Barrel" then local st=z:FindFirstChild("State"); if st and st.Value~="Spawn" and st.Value~="Stunned" and (z.HumanoidRootPart.Position-root.Position).Magnitude<=50 then remote:FireServer("BraceBlock"); remote:FireServer("StopBraceBlock"); remote:FireServer("FeedbackStun",z,z.HumanoidRootPart.Position) end end end end
    end
    local function onEngineerAnim(track)
        local aid = track.Animation.AnimationId
        if _S.Config.engineerRecycle and (aid=="rbxassetid://114385794993502" or aid=="rbxassetid://12638403582" or aid=="rbxassetid://12638409326" or aid=="rbxassetid://15345113937") then
            task.delay(aid=="rbxassetid://15345113937" and 0.2 or aid=="rbxassetid://12638409326" and 0.9 or 0.85, recycleAxe)
        end
        if _S.Config.engineerElbow and aid=="rbxassetid://15345113937" then stunAround() end
    end
    _S.updateEngineerConn = function()
        if engineerAnimConn then engineerAnimConn:Disconnect(); engineerAnimConn=nil end
        if not (_S.Config.engineerRecycle or _S.Config.engineerElbow) then return end
        local char = _S.lp.Character
        if not char then _S.lp.CharacterAdded:Connect(function() task.wait(1); _S.updateEngineerConn() end) return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then engineerAnimConn = hum.AnimationPlayed:Connect(onEngineerAnim) end
    end
    _S.startAutoElbow = function()
        if elbowConn then return end
        _S.Config.autoElbow = true
        elbowConn = _S.RunService.Heartbeat:Connect(function()
            if not _S.Config.autoElbow then return end
            local now = tick()
            if now - lastElbow < 0.2 then return end
            lastElbow = now
            local char = _S.lp.Character
            if not char then return end
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hum or hum.Health<=0 then return end
            local weapon = nil
            for _,t in pairs(char:GetChildren()) do if t:IsA("Tool") and t:GetAttribute("Melee") then weapon=t; break end end
            if not weapon or weapon.Name~="Axe" then return end
            local zf = _S.Workspace:FindFirstChild("Zombies")
            if zf then for _,z in pairs(zf:GetChildren()) do if z:IsA("Model") and z:FindFirstChild("HumanoidRootPart") then
                if (z.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude <= 45 then
                    if z:FindFirstChild("State") and z.State.Value~="Stunned" then
                        weapon.RemoteEvent:FireServer("BraceBlock")
                        weapon.RemoteEvent:FireServer("StopBraceBlock")
                        weapon.RemoteEvent:FireServer("FeedbackStun",z,z.HumanoidRootPart.Position)
                    end
                end
            end end end
        end)
    end
    _S.stopAutoElbow = function() _S.Config.autoElbow=false; if elbowConn then elbowConn:Disconnect(); elbowConn=nil end end
    local function onJumpAnim(track)
        if _S.Config.officerAutoJump and track.Animation.AnimationId == "rbxassetid://12591948314" then
            local char = _S.lp.Character
            if char then
                local hum = char:FindFirstChildOfClass("Humanoid")
                local root = char:FindFirstChild("HumanoidRootPart")
                if hum and root then hum:ChangeState(Enum.HumanoidStateType.Jumping); root.Velocity = Vector3.new(root.Velocity.X,35,root.Velocity.Z) end
            end
        end
    end
    _S.setupOfficerJump = function()
        if officerJumpConn then officerJumpConn:Disconnect(); officerJumpConn=nil end
        if not _S.Config.officerAutoJump then return end
        local char = _S.lp.Character
        if not char then _S.lp.CharacterAdded:Connect(function() task.wait(1); _S.setupOfficerJump() end) return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then officerJumpConn = hum.AnimationPlayed:Connect(onJumpAnim) end
    end
    local function getGun()
        local char = _S.lp.Character
        if char then for _,t in pairs(char:GetChildren()) do if t:IsA("Tool") and isGun(t) then return t end end end
        for _,t in pairs(_S.lp.Backpack:GetChildren()) do if t:IsA("Tool") and isGun(t) then return t end end
        return nil
    end
    local function equipGun(gun) if gun and gun.Parent~=_S.lp.Character then gun.Parent=_S.lp.Character; task.wait(0.05); local r=gun:FindFirstChild("RemoteEvent"); if r then pcall(function() r:FireServer("Activate") end) end end end
    local function getClosestBarrel()
        local char = _S.lp.Character
        if not char then return nil end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return nil end
        local camf = _S.Workspace:FindFirstChild("Camera")
        if not camf then return nil end
        local bestPart,bestDist = nil,_S.Config.shootRange+1
        for _,m in pairs(camf:GetChildren()) do
            if m:IsA("Model") and m:FindFirstChild("Barrel") then
                local target = m:FindFirstChild("Head") or m:FindFirstChild("HumanoidRootPart")
                if target and target:IsA("BasePart") then
                    local dist = (target.Position - root.Position).Magnitude
                    if dist <= _S.Config.shootRange and dist < bestDist then
                        local params = RaycastParams.new()
                        params.FilterType = Enum.RaycastFilterType.Blacklist
                        params.FilterDescendantsInstances = {char, _S.Workspace:FindFirstChild("Zombies")}
                        local hit = _S.Workspace:Raycast(root.Position, (target.Position - root.Position), params)
                        if not hit then bestDist=dist; bestPart=target end
                    end
                end
            end
        end
        return bestPart
    end
    _S.shootLoop = function()
        while _S.Config.autoShoot do
            local target = getClosestBarrel()
            if not target then task.wait(0.15) continue end
            local gun = getGun()
            if not gun then task.wait(0.3) continue end
            equipGun(gun)
            local ammo = getShots(gun)
            if ammo == 0 then tryReload(gun); task.wait(0.5) continue end
            task.wait(0.3)
            if not target.Parent then continue end
            ammo = getShots(gun)
            if ammo == 0 then continue end
            local remote = findRemote(gun)
            if remote then
                local serverTime = _S.Workspace:GetServerTimeNow()
                pcall(function() remote:FireServer("Fire", _S.lp.Character or _S.lp, target.Position, serverTime) end)
            end
            task.wait(0.25)
        end
    end
    _S.startShoot = function() if shootThread then return end; _S.Config.autoShoot=true; shootThread=task.spawn(_S.shootLoop) end
    _S.stopShoot = function() _S.Config.autoShoot=false; if shootThread then task.cancel(shootThread); shootThread=nil end end
end

do
    local silentCache = {}; local silentLast = 0; local pvpCache = {}; local pvpLast = 0
    local oldNamecall, oldIndex, oldRayNew
    local function getZombieType(m)
        if m:FindFirstChild("Axe") then return "Axe"
        elseif m:FindFirstChild("Eye") then return "Eye"
        elseif m:FindFirstChild("Sword") then return "Sword"
        elseif m:FindFirstChild("Barrel") then return "Barrel"
        elseif m:FindFirstChild("FTorso") then return "FTorso"
        else return nil end
    end
    local function updateSilent()
        if not _S.Config.silentAim then silentCache={}; return end
        local new = {}
        local cam = _S.Workspace:FindFirstChild("Camera") or _S.Workspace
        for _,m in pairs(cam:GetDescendants()) do
            if m:IsA("Model") then
                local zt = getZombieType(m)
                if zt and _S.Config.silentAimTypes[zt] then
                    local state = m:FindFirstChild("State")
                    if state and state.Value=="Spawn" then continue end
                    local hum = m:FindFirstChildOfClass("Humanoid")
                    if hum and hum.Health<=0 then continue end
                    local part = (_S.Config.silentAimPart=="Head" and m:FindFirstChild("Head")) or m:FindFirstChild("HumanoidRootPart") or m:FindFirstChild("Torso")
                    if part then table.insert(new,part) end
                end
            end
        end
        silentCache = new
        silentLast = tick()
    end
    local function getClosestSilent()
        if #silentCache==0 then return nil end
        if _S.Config.silentAimMode=="FOV" then
            local center = _S.camera.ViewportSize/2
            local best,bestDist = nil,_S.Config.silentAimFOV+1
            for _,p in ipairs(silentCache) do
                local sp,on = _S.camera:WorldToViewportPoint(p.Position)
                if on then
                    local d = (Vector2.new(sp.X,sp.Y)-center).Magnitude
                    if d<bestDist then bestDist=d; best=p end
                end
            end
            return best
        else
            local char = _S.lp.Character
            if not char then return nil end
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then return nil end
            local best,bestDist = nil,math.huge
            for _,p in ipairs(silentCache) do
                local d = (root.Position - p.Position).Magnitude
                if d<bestDist then bestDist=d; best=p end
            end
            return best
        end
    end
    local function updatePVP()
        if not _S.Config.pvpAimEnabled then pvpCache={}; return end
        local new = {}
        for _,pl in pairs(game:GetService("Players"):GetPlayers()) do
            if pl~=_S.lp then
                if not _S.Config.pvpAllowFriends and pl:IsFriendsWith(_S.lp.UserId) then continue end
                local char = pl.Character
                if char then
                    local part = (_S.Config.pvpAimPart=="Head" and char:FindFirstChild("Head")) or char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
                    if part then table.insert(new,part) end
                end
            end
        end
        pvpCache = new
        pvpLast = tick()
    end
    local function getClosestPVP()
        if #pvpCache==0 then return nil end
        if _S.Config.pvpAimMode=="FOV" then
            local center = _S.camera.ViewportSize/2
            local best,bestDist = nil,_S.Config.pvpAimFOV+1
            for _,p in ipairs(pvpCache) do
                local sp,on = _S.camera:WorldToViewportPoint(p.Position)
                if on then
                    local d = (Vector2.new(sp.X,sp.Y)-center).Magnitude
                    if d<bestDist then bestDist=d; best=p end
                end
            end
            return best
        else
            local char = _S.lp.Character
            if not char then return nil end
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then return nil end
            local best,bestDist = nil,math.huge
            for _,p in ipairs(pvpCache) do
                local d = (root.Position - p.Position).Magnitude
                if d<bestDist then bestDist=d; best=p end
            end
            return best
        end
    end
    local function getAimPart()
        if _S.Config.pvpAimEnabled then
            if tick()-pvpLast > _S.Config.silentScanInterval then updatePVP() end
            local p = getClosestPVP()
            if p then 
                _S.currentAimTarget = p
                return p 
            end
        end
        if _S.Config.silentAim then
            if tick()-silentLast > _S.Config.silentScanInterval then updateSilent() end
            local target = getClosestSilent()
            if target then
                _S.currentAimTarget = target
            else
                _S.currentAimTarget = nil
            end
            return target
        end
        _S.currentAimTarget = nil
        return nil
    end
    local function enableHooks()
        if oldNamecall then return end
        oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
            local method = getnamecallmethod()
            local args = {...}
            local aim = getAimPart()
            if aim and not checkcaller() then
                if method=="Raycast" and self==workspace then
                    local origin = args[1]
                    local dir = args[2]
                    local newDir = (aim.Position - origin).Unit * (dir and dir.Magnitude or 1000)
                    return oldNamecall(self, origin, newDir, args[3])
                elseif method:find("FindPartOnRay") then
                    local ray = args[2]
                    if ray and ray.Origin then
                        local newRay = Ray.new(ray.Origin, (aim.Position - ray.Origin).Unit * 1000)
                        args[2] = newRay
                        return oldNamecall(self, unpack(args))
                    end
                elseif (method=="ViewportPointToRay" or method=="ScreenPointToRay") and self==_S.camera then
                    return Ray.new(_S.camera.CFrame.Position, (aim.Position - _S.camera.CFrame.Position).Unit)
                end
            end
            return oldNamecall(self, ...)
        end))
        oldIndex = hookmetamethod(game, "__index", newcclosure(function(self, key)
            local aim = getAimPart()
            if aim and not checkcaller() and self==_S.lp:GetMouse() then
                if key=="Target" or key=="target" then return aim
                elseif key=="Hit" or key=="hit" then return aim.CFrame
                elseif key=="UnitRay" then return Ray.new(_S.camera.CFrame.Position, (aim.Position - _S.camera.CFrame.Position).Unit)
                end
            end
            return oldIndex(self, key)
        end))
        oldRayNew = hookfunction(Ray.new, newcclosure(function(origin, direction)
            local aim = getAimPart()
            if aim and not checkcaller() then
                local newDir = (aim.Position - origin).Unit * (direction.Magnitude or 1000)
                return oldRayNew(origin, newDir)
            end
            return oldRayNew(origin, direction)
        end))
    end
    local function disableHooks()
        if oldNamecall then oldNamecall:Unhook(); oldNamecall=nil end
        if oldIndex then oldIndex:Unhook(); oldIndex=nil end
        if oldRayNew then oldRayNew:Unhook(); oldRayNew=nil end
    end
    _S.enableHooks = enableHooks
    _S.disableHooks = disableHooks
end

do
    _S.exportConfig = function()
        local json = _S.HttpService:JSONEncode(_S.Config)
        setclipboard(json)
        Windows:Notify("配置已导出")
    end
    _S.importConfig = function()
        local success, data = pcall(_S.HttpService.JSONDecode, _S.HttpService, getclipboard())
        if success and type(data)=="table" then
            for k,v in pairs(data) do _S.Config[k]=v end
            Windows:Notify("配置已加载")
            _S.updateWalkSpeed()
            if _S.Config.jumpModEnabled then _S.startAntiFall() else _S.stopAntiFall() end
            if _S.Config.autoFaceEnabled then _S.startAutoFace() else _S.stopAutoFace() end
            if _S.Config.noSlowActive then _S.setupNoSlow() end
            if _S.Config.noFallActive then task.spawn(_S.preventFallDamage) end
            if _S.Config.autoDoorEnabled then task.spawn(_S.autoDoorLoop) end
            if _S.Config.autoDig then task.spawn(_S.autoDigLoop) end
            if _S.Config.autoLog then task.spawn(_S.autoLogLoop) end
            if _S.Config.autoPlace then task.spawn(_S.autoPlaceLoop) end
            if _S.Config.autoRepairBridge then 
                if _S.repairBridgeConn then _S.repairBridgeConn:Disconnect() end
                _S.repairBridgeConn = _S.RunService.Heartbeat:Connect(_S.doRepairBridge)
            end
            if _S.Config.autoCollect then _S.setupAutoCollect() end
            if _S.Config.auraEnabled then _S.startAura() else _S.stopAura() end
            if _S.Config.killWaveEnabled then _S.startWaveMode() end
            if _S.Config.killAnimEnabled then _S.updateKillAnimConn() end
            if _S.Config.hammerAuto then _S.startHammer() else _S.stopHammer() end
            if _S.Config.engineerRecycle or _S.Config.engineerElbow then _S.updateEngineerConn() end
            if _S.Config.autoElbow then _S.startAutoElbow() else _S.stopAutoElbow() end
            if _S.Config.officerAutoJump then _S.setupOfficerJump() end
            if _S.Config.autoShoot then _S.startShoot() else _S.stopShoot() end
            if _S.Config.silentAim or _S.Config.pvpAimEnabled then _S.enableHooks() else _S.disableHooks() end
            _S.startESPUpdate()
        else
            Windows:Notify("配置加载失败",2,"error")
        end
    end
end

do
    local healMoveConn = nil
    local fixFireConn = nil
    local trajectoryConn = nil
    local noSpreadConn = nil
    local function toggleHealMove()
        if healMoveConn then healMoveConn:Disconnect(); healMoveConn = nil end
        if not _S.Config.healCanMove then return end
        healMoveConn = _S.RunService.Heartbeat:Connect(function()
            local hum = _S.lp.Character and _S.lp.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.PlatformStand then
                hum.PlatformStand = false
            end
        end)
    end
    local function fixFireLag()
        local function setFireEnabled(enabled)
            for _, obj in pairs(_S.Workspace:GetDescendants()) do
                if obj:IsA("ParticleEmitter") and obj.Name:lower():find("fire") then
                    obj.Enabled = enabled
                    if not enabled then obj.Rate = 0 else obj.Rate = 20 end
                end
            end
        end
        if _S.Config.fixFireLag then
            setFireEnabled(false)
            if not fixFireConn then
                fixFireConn = _S.Workspace.DescendantAdded:Connect(function(desc)
                    if _S.Config.fixFireLag and desc:IsA("ParticleEmitter") and desc.Name:lower():find("fire") then
                        desc.Enabled = false
                        desc.Rate = 0
                    end
                end)
            end
        else
            if fixFireConn then fixFireConn:Disconnect(); fixFireConn = nil end
            setFireEnabled(true)
        end
    end
    local function setupTrajectory()
        if trajectoryConn then trajectoryConn:Disconnect(); trajectoryConn = nil end
        if not _S.Config.showTrajectory then return end
        trajectoryConn = _S.Workspace.DescendantAdded:Connect(function(desc)
            if _S.Config.showTrajectory and desc:IsA("Model") and desc:FindFirstChild("HumanoidRootPart") == nil then
                task.wait(0.03)
                local start = desc.PrimaryPart and desc.PrimaryPart.Position or desc:GetPivot().Position
                task.wait(0.05)
                local finish = desc.PrimaryPart and desc.PrimaryPart.Position or desc:GetPivot().Position
                if start and finish and (finish - start).Magnitude > 0.5 then
                    local line = Instance.new("Part")
                    line.Size = Vector3.new(0.1, 0.1, (finish - start).Magnitude)
                    line.CFrame = CFrame.lookAt(start, finish) * CFrame.new(0, 0, -line.Size.Z/2)
                    line.BrickColor = BrickColor.new("Bright red")
                    line.Material = Enum.Material.Neon
                    line.Anchored = true
                    line.CanCollide = false
                    line.Parent = _S.Workspace
                    game:GetService("Debris"):AddItem(line, 0.8)
                end
            end
        end)
    end
    local originalSpread = {}
    local function applyNoSpread()
        local function processTool(tool)
            if tool:IsA("Tool") and tool:FindFirstChild("Spread") then
                if _S.Config.noSpread then
                    if not originalSpread[tool] then
                        originalSpread[tool] = tool.Spread.Value
                    end
                    tool.Spread.Value = 0
                else
                    if originalSpread[tool] then
                        tool.Spread.Value = originalSpread[tool]
                    end
                end
            end
        end
        for _, tool in pairs(_S.lp.Backpack:GetChildren()) do processTool(tool) end
        if _S.lp.Character then
            for _, tool in pairs(_S.lp.Character:GetChildren()) do processTool(tool) end
        end
        if noSpreadConn then noSpreadConn:Disconnect() end
        if _S.Config.noSpread then
            noSpreadConn = _S.lp.Backpack.ChildAdded:Connect(processTool)
            if _S.lp.Character then
                _S.lp.Character.ChildAdded:Connect(processTool)
            end
        end
    end
    _S.toggleHealMove = toggleHealMove
    _S.toggleFixFire = fixFireLag
    _S.toggleTrajectory = setupTrajectory
    _S.toggleNoSpread = applyNoSpread
end

do
    local speedLabel = nil
    _S.createSpeedDisplay = function()
        if speedLabel then speedLabel:Destroy() end
        if not _S.Config.showSpeedValue then return end
        speedLabel = Instance.new("TextLabel")
        speedLabel.Size = UDim2.new(0,100,0,30)
        speedLabel.Position = UDim2.new(1,-110,0,10)
        speedLabel.BackgroundTransparency = 0.5
        speedLabel.BackgroundColor3 = Color3.new(0,0,0)
        speedLabel.TextColor3 = Color3.new(1,1,1)
        speedLabel.TextSize = 14
        speedLabel.Font = Enum.Font.GothamBold
        speedLabel.Parent = _S.pgui
        task.spawn(function()
            while _S.Config.showSpeedValue and speedLabel and speedLabel.Parent do
                local hum = _S.lp.Character and _S.lp.Character:FindFirstChildOfClass("Humanoid")
                speedLabel.Text = "速度: " .. (hum and string.format("%.1f",hum.WalkSpeed) or "0")
                task.wait(0.1)
            end
            if speedLabel then speedLabel:Destroy() end
        end)
    end
end

-- 模块13：静默自瞄红外红点
do
    local aimDot = nil
    local aimDotSize = 15
    local aimDotEnabled = false
    local renderConn = nil
    
    local function createDot()
        if aimDot then aimDot:Remove() end
        aimDot = Drawing.new("Circle")
        aimDot.Visible = false
        aimDot.Color = Color3.new(1, 0, 0)
        aimDot.Thickness = 2
        aimDot.NumSides = 32
        aimDot.Filled = true
        aimDot.Transparency = 0.4
        aimDot.Radius = aimDotSize
    end
    
    local function updateDot()
        if not aimDotEnabled or not _S.Config.silentAim then
            if aimDot then aimDot.Visible = false end
            return
        end
        
        local target = _S.currentAimTarget
        if target and target.Parent and target:IsA("BasePart") then
            local screenPos, onScreen = _S.camera:WorldToViewportPoint(target.Position)
            if onScreen then
                if not aimDot then createDot() end
                aimDot.Position = Vector2.new(screenPos.X, screenPos.Y)
                aimDot.Visible = true
                aimDot.Radius = aimDotSize
                return
            end
        end
        if aimDot then aimDot.Visible = false end
    end
    
    local function toggleRedDot(enabled)
        aimDotEnabled = enabled
        if enabled then
            if not aimDot then createDot() end
            if not renderConn then
                renderConn = _S.RunService.RenderStepped:Connect(updateDot)
            end
        else
            if renderConn then renderConn:Disconnect(); renderConn = nil end
            if aimDot then aimDot.Visible = false end
        end
    end
    
    local function setDotSize(size)
        aimDotSize = size
        if aimDot then aimDot.Radius = size end
    end
    
    _S.toggleRedDot = toggleRedDot
    _S.setDotSize = setDotSize
end

-- ==================== 新增功能（碰飞、僵尸碰撞箱仅自爆、回溯、点击传送、自动跳跃） ====================
-- 1. 碰飞功能
do
    local rammingEnabled = false
    local rammingTarget = nil
    local rammingFollowConn = nil
    local rammingMoveConn = nil
    
    local function findPlayer(text)
        text = text:lower()
        for _, plr in pairs(game:GetService("Players"):GetPlayers()) do
            if string.find(plr.Name:lower(), text) or string.find(plr.DisplayName:lower(), text) then
                return plr
            end
        end
    end
    
    local function startRamming()
        if rammingFollowConn then rammingFollowConn:Disconnect() end
        if rammingMoveConn then rammingMoveConn:Disconnect() end
        
        rammingFollowConn = _S.RunService.Heartbeat:Connect(function()
            if not rammingEnabled then return end
            if not rammingTarget then return end
            local char = rammingTarget.Character
            if not char or not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then
                rammingTarget = nil
                return
            end
            local myChar = _S.lp.Character
            local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
            local targetHRP = char:FindFirstChild("HumanoidRootPart")
            if myHRP and targetHRP then
                local offset = targetHRP.Velocity.Magnitude < 0.1 and 0 or 7
                local goal = targetHRP.CFrame * CFrame.new(0,0,-offset) * CFrame.Angles(0, math.rad(-3), 0)
                myHRP.CFrame = myHRP.CFrame:Lerp(goal, 0.4)
                myHRP.Velocity = Vector3.new(0,0,0)
                myHRP.RotVelocity = Vector3.new(0,0,0)
            end
        end)
        
        rammingMoveConn = _S.RunService.Stepped:Connect(function()
            if not rammingEnabled then return end
            local hum = _S.lp.Character and _S.lp.Character:FindFirstChild("Humanoid")
            if hum then
                hum:Move(Vector3.one * 1e31)
            end
        end)
        
        _S.lp.Chatted:Connect(function(msg)
            if not rammingEnabled then return end
            if msg:sub(1,6):lower() == ";kill " then
                local name = msg:sub(7)
                local plr = findPlayer(name)
                if plr and plr.Character and plr.Character:FindFirstChild("Humanoid") then
                    rammingTarget = plr
                    Windows:Notify("已锁定 " .. plr.Name, 2)
                end
            end
        end)
    end
    
    local function stopRamming()
        if rammingFollowConn then rammingFollowConn:Disconnect(); rammingFollowConn = nil end
        if rammingMoveConn then rammingMoveConn:Disconnect(); rammingMoveConn = nil end
        rammingTarget = nil
    end
    
    _S.startRamming = function()
        if rammingEnabled then return end
        rammingEnabled = true
        startRamming()
    end
    
    _S.stopRamming = function()
        rammingEnabled = false
        stopRamming()
    end
end

-- 2. 僵尸碰撞箱移除 **修改为仅对自爆僵尸（Barrel）有效**
do
    local zombieCollisionActive = false
    local originalCollisionStates = {}
    local originalQueryStates = {}
    local descendantConn = nil
    
    local function isBarrelZombie(model)
        if model:FindFirstChild("Barrel") then return true end
        if model:GetAttribute("Type") == "Barrel" then return true end
        if model.Name:lower():find("barrel") then return true end
        return false
    end
    
    local function getAllZombies()
        local zombies = {}
        local zombiesFolder = _S.Workspace:FindFirstChild("Zombies")
        if zombiesFolder then
            for _, child in ipairs(zombiesFolder:GetChildren()) do
                if child:IsA("Model") and child:FindFirstChild("HumanoidRootPart") then
                    table.insert(zombies, child)
                end
            end
        end
        for _, child in ipairs(_S.Workspace:GetChildren()) do
            if child:IsA("Model") and child.Name:lower():find("zombie") and not table.find(zombies, child) then
                table.insert(zombies, child)
            end
        end
        return zombies
    end
    
    local function getAllParts(model)
        local parts = {}
        for _, descendant in pairs(model:GetDescendants()) do
            if descendant:IsA("BasePart") then
                table.insert(parts, descendant)
            end
        end
        return parts
    end
    
    local function setZombieEffect(zombie, enabled)
        if not zombie or not zombie.Parent then return end
        if not isBarrelZombie(zombie) then return end
        
        local parts = getAllParts(zombie)
        for _, part in ipairs(parts) do
            if enabled then
                if originalCollisionStates[part] == nil then
                    originalCollisionStates[part] = part.CanCollide
                end
                if originalQueryStates[part] == nil then
                    originalQueryStates[part] = part.CanQuery
                end
                part.CanCollide = false
                part.CanQuery = false
            else
                if originalCollisionStates[part] ~= nil then
                    part.CanCollide = originalCollisionStates[part]
                else
                    part.CanCollide = true
                end
                if originalQueryStates[part] ~= nil then
                    part.CanQuery = originalQueryStates[part]
                else
                    part.CanQuery = true
                end
            end
        end
    end
    
    local function applyToAllZombies(disable)
        local zombies = getAllZombies()
        for _, zombie in ipairs(zombies) do
            setZombieEffect(zombie, disable)
        end
    end
    
    local function onZombieAdded(zombie)
        if zombieCollisionActive and zombie:IsA("Model") and zombie:FindFirstChild("HumanoidRootPart") then
            setZombieEffect(zombie, true)
        end
    end
    
    local function startZombieCollisionRemoval()
        if descendantConn then descendantConn:Disconnect() end
        descendantConn = _S.Workspace.DescendantAdded:Connect(function(desc)
            if desc:IsA("Model") and (desc.Parent and desc.Parent.Name == "Zombies" or desc.Name:lower():find("zombie")) then
                onZombieAdded(desc)
            end
        end)
        applyToAllZombies(true)
    end
    
    local function stopZombieCollisionRemoval()
        if descendantConn then descendantConn:Disconnect(); descendantConn = nil end
        applyToAllZombies(false)
        originalCollisionStates = {}
        originalQueryStates = {}
    end
    
    _S.startZombieCollisionRemoval = function()
        if zombieCollisionActive then return end
        zombieCollisionActive = true
        startZombieCollisionRemoval()
    end
    
    _S.stopZombieCollisionRemoval = function()
        zombieCollisionActive = false
        stopZombieCollisionRemoval()
    end
end

-- 3. 回溯传送（站立修正）
do
    local standWalkActive = false
    local originalCFrames = {}
    
    local function getBodyParts(character)
        local parts = {}
        if not character then return parts end
        for _, child in ipairs(character:GetChildren()) do
            if child:IsA("BasePart") and child.Name ~= "HumanoidRootPart" then
                table.insert(parts, child)
            end
        end
        return parts
    end
    
    local function applyNormal(character)
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return end
        
        local bodyParts = getBodyParts(character)
        for _, part in ipairs(bodyParts) do
            if not originalCFrames[part] then
                originalCFrames[part] = part.CFrame
            end
            local relativeCF = rootPart.CFrame:ToObjectSpace(part.CFrame)
            local normalCF = relativeCF * CFrame.Angles(0, 0, 0)
            part.CFrame = rootPart.CFrame:ToWorldSpace(normalCF)
        end
    end
    
    local function restoreOriginal(character)
        for part, originalCF in pairs(originalCFrames) do
            if part and part.Parent then
                part.CFrame = originalCF
            end
        end
        originalCFrames = {}
    end
    
    local function onCharacterAdded(character)
        if standWalkActive then
            character:WaitForChild("HumanoidRootPart")
            task.wait(0.1)
            applyNormal(character)
        end
    end
    
    _S.startStandWalk = function()
        if standWalkActive then return end
        standWalkActive = true
        if _S.lp.Character then
            onCharacterAdded(_S.lp.Character)
        end
        _S.lp.CharacterAdded:Connect(onCharacterAdded)
    end
    
    _S.stopStandWalk = function()
        standWalkActive = false
        if _S.lp.Character then
            restoreOriginal(_S.lp.Character)
        end
    end
end

-- 4. 点击传送
do
    local clickTeleportActive = false
    local mouse = _S.lp:GetMouse()
    
    local function teleportTo(position)
        local character = _S.lp.Character
        if not character then return end
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if rootPart then
            local adjustedPos = position + Vector3.new(0, 2.5, 0)
            rootPart.CFrame = CFrame.new(adjustedPos)
        end
    end
    
    local clickConn = nil
    _S.startClickTeleport = function()
        if clickTeleportActive then return end
        clickTeleportActive = true
        if clickConn then clickConn:Disconnect() end
        clickConn = mouse.Button1Down:Connect(function()
            if clickTeleportActive then
                local clickPos = mouse.Hit.p
                if clickPos then
                    teleportTo(clickPos)
                end
            end
        end)
    end
    
    _S.stopClickTeleport = function()
        clickTeleportActive = false
        if clickConn then clickConn:Disconnect(); clickConn = nil end
    end
end

-- 5. 无限连跳（自动跳跃）
do
    local autoJumpActive = false
    local autoJumpHeight = 60
    local autoJumpConn = nil
    
    local function checkAndJump()
        if not autoJumpActive then return end
        local character = _S.lp.Character
        if not character then return end
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if not humanoid or not rootPart then return end
        local onGround = humanoid.FloorMaterial ~= Enum.Material.Air
        if onGround then
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            rootPart.Velocity = Vector3.new(rootPart.Velocity.X, autoJumpHeight, rootPart.Velocity.Z)
        end
    end
    
    _S.startAutoJump = function()
        if autoJumpActive then return end
        autoJumpActive = true
        if autoJumpConn then autoJumpConn:Disconnect() end
        autoJumpConn = _S.RunService.Heartbeat:Connect(checkAndJump)
    end
    
    _S.stopAutoJump = function()
        autoJumpActive = false
        if autoJumpConn then autoJumpConn:Disconnect(); autoJumpConn = nil end
    end
    
    _S.setAutoJumpHeight = function(height)
        autoJumpHeight = math.clamp(height, 30, 60)
    end
end

