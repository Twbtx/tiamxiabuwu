-- 工兵新增：自动修复（注视建筑）
local autoRepairBuilding = false
local repairCooldown = 0.1
local lastRepairTime = 0
local function getLookedBuildHealth()
    local char = _S.lp.Character
    if not char then return nil end
    local camera = _S.camera
    local origin = camera.CFrame.Position
    local direction = camera.CFrame.LookVector * 50
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {char}
    params.FilterType = Enum.RaycastFilterType.Blacklist
    local result = workspace:Raycast(origin, direction, params)
    if not result then return nil end
    local hit = result.Instance
    local model = hit:FindFirstAncestorOfClass("Model")
    if not model then return nil end
    local buildHealth = model:FindFirstChild("BuildingHealth") or (model.Parent and model.Parent:FindFirstChild("BuildingHealth"))
    return buildHealth
end
local function autoRepairLoop()
    while autoRepairBuilding do
        local now = tick()
        if now - lastRepairTime >= repairCooldown then
            local buildHealth = getLookedBuildHealth()
            if buildHealth then
                local current = buildHealth.Value
                local maxHealth = buildHealth:GetAttribute("MaxHealth")
                if maxHealth and current < maxHealth then
                    local hammer = _S.lp.Backpack:FindFirstChild("Hammer") or _S.lp.Backpack:FindFirstChild("Claw Hammer")
                    if hammer and hammer:FindFirstChild("RemoteEvent") then
                        if hammer.Parent ~= _S.lp.Character then hammer.Parent = _S.lp.Character end
                        hammer.RemoteEvent:FireServer("Repair", buildHealth)
                        lastRepairTime = now
                    end
                end
            end
        end
        task.wait(0.1)
    end
end
EngineerSection:NewToggle({ Title = "自动修复", Default = false, Callback = function(s)
    autoRepairBuilding = s
    if s then task.spawn(autoRepairLoop) end
end })

