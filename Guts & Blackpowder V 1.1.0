-- 牧师功能：自动祝福感染玩家
local autoBless = false
local blessThreshold = 50
local blessCooldown = 2
local blessRange = 15
local lastBlessRequest = {}
local blessLoopThread = nil

local function getPlayerInfection(player)
    local infection = 0
    pcall(function()
        local wsPlayers = workspace:FindFirstChild("Players")
        if wsPlayers then
            local folder = wsPlayers:FindFirstChild(player.Name)
            if folder and folder:FindFirstChild("UserStates") then
                local v = folder.UserStates:FindFirstChild("Infected")
                if v then infection = tonumber(v.Value) or 0 return end
            end
        end
        if player:FindFirstChild("UserStates") then
            local v = player.UserStates:FindFirstChild("Infected")
            if v then infection = tonumber(v.Value) or 0 end
        end
    end)
    return infection
end

local function getBlessRemote()
    local char = _S.lp.Character
    if not char then return nil end
    local tool = char:FindFirstChild("Blessing")
    if tool and tool:FindFirstChild("RemoteEvent") then return tool.RemoteEvent end
    for _, child in pairs(char:GetChildren()) do
        if child:IsA("Tool") and child.Name:lower():find("bless") and child:FindFirstChild("RemoteEvent") then
            return child.RemoteEvent
        end
    end
    return nil
end

local function sendBless(player)
    if not player or not player.Character then return end
    local infection = getPlayerInfection(player)
    if infection < blessThreshold then return end
    local last = lastBlessRequest[player] or 0
    if tick() - last < blessCooldown then return end
    
    local char = _S.lp.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local targetRoot = player.Character:FindFirstChild("HumanoidRootPart") or player.Character:FindFirstChild("Torso")
    if not targetRoot then return end
    if (root.Position - targetRoot.Position).Magnitude > blessRange then return end
    
    local remote = getBlessRemote()
    if remote then
        pcall(function() remote:FireServer("SendRequest", player.Character:FindFirstChildOfClass("Humanoid")) end)
        lastBlessRequest[player] = tick()
        Windows:Notify("已祝福 " .. player.Name, 2)
    end
end

local function startBlessLoop()
    if blessLoopThread then return end
    blessLoopThread = task.spawn(function()
        while autoBless do
            for _, plr in pairs(game:GetService("Players"):GetPlayers()) do
                if plr ~= _S.lp and plr.Character then
                    sendBless(plr)
                end
            end
            task.wait(0.5)
        end
        blessLoopThread = nil
    end)
end

ChaplainSection:NewToggle({ Title = "自动祝福感染玩家", Default = false, Callback = function(s)
    autoBless = s
    if s then startBlessLoop() else if blessLoopThread then task.cancel(blessLoopThread); blessLoopThread = nil end; lastBlessRequest = {} end
end })
ChaplainSection:NewSlider({ Title = "感染阈值 (0-200)", Min = 0, Max = 200, Default = 50, Callback = function(v) blessThreshold = v end })
ChaplainSection:NewSlider({ Title = "祝福范围 (格)", Min = 5, Max = 30, Default = 15, Callback = function(v) blessRange = v end })

-- 医生（医疗兵）功能：自动请求治疗濒死玩家
local autoRequestHeal = false
local healThreshold = 25
local healCooldown = 3
local healRange = 15
local lastHealRequest = {}
local healLoopThread = nil

local function requestHeal(player, humanoid)
    if not player or not humanoid then return end
    local healthPercent = (humanoid.Health / humanoid.MaxHealth) * 100
    if healthPercent > healThreshold then return end
    local last = lastHealRequest[player] or 0
    if tick() - last < healCooldown then return end
    lastHealRequest[player] = tick()
    
    local char = _S.lp.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local targetRoot = humanoid.Parent:FindFirstChild("HumanoidRootPart") or humanoid.Parent:FindFirstChild("Torso")
    if not targetRoot then return end
    if (root.Position - targetRoot.Position).Magnitude > healRange then return end
    
    local medSupplies = char:FindFirstChild("Medical Supplies")
    if not medSupplies then return end
    local remote = medSupplies:FindFirstChild("RemoteEvent")
    if remote then
        pcall(function() remote:FireServer("SendRequest", humanoid) end)
        Windows:Notify("已请求治疗 " .. player.Name, 2)
    end
end

local function startHealLoop()
    if healLoopThread then return end
    healLoopThread = task.spawn(function()
        while autoRequestHeal do
            for _, plr in pairs(game:GetService("Players"):GetPlayers()) do
                if plr ~= _S.lp and plr.Character then
                    local hum = plr.Character:FindFirstChildOfClass("Humanoid")
                    if hum and hum.Health > 0 then
                        requestHeal(plr, hum)
                    end
                end
            end
            task.wait(0.5)
        end
        healLoopThread = nil
    end)
end

DoctorSection:NewToggle({ Title = "自动请求治疗濒死玩家", Default = false, Callback = function(s)
    autoRequestHeal = s
    if s then startHealLoop() else if healLoopThread then task.cancel(healLoopThread); healLoopThread = nil end; lastHealRequest = {} end
end })
DoctorSection:NewSlider({ Title = "治疗阈值 (%)", Min = 1, Max = 100, Default = 25, Callback = function(v) healThreshold = v end })
DoctorSection:NewSlider({ Title = "治疗范围 (格)", Min = 5, Max = 30, Default = 15, Callback = function(v) healRange = v end })

