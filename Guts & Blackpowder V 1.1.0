-- 修复后的“删除UI”按钮，彻底停止所有功能并销毁UI，最后通过error终止脚本
ConfigSection:NewButton({ Title = "删除UI", Callback = function()
    -- 停止所有主要功能
    if _S.stopAura then _S.stopAura() end
    if _S.stopWaveMode then _S.stopWaveMode() end
    if _S.disableHooks then _S.disableHooks() end
    if _S.stopFly_orig then _S.stopFly_orig() end
    if _S.stopFly_new then _S.stopFly_new() end
    _S.Config.autoDig = false
    _S.Config.autoLog = false
    _S.Config.autoPlace = false
    _S.Config.autoRepairBridge = false
    _S.Config.autoCollect = false
    _S.Config.autoDoorEnabled = false
    if _S.stopHammer then _S.stopHammer() end
    if _S.stopAutoElbow then _S.stopAutoElbow() end
    if _S.stopShoot then _S.stopShoot() end
    if _S.stopRamming then _S.stopRamming() end
    if _S.toggleHealMove then _S.toggleHealMove() end
    if _S.toggleTrajectory then _S.toggleTrajectory() end
    if _S.toggleNoSpread then _S.toggleNoSpread() end
    if _S.toggleFixFire then _S.toggleFixFire() end
    _S.Config.showSpeedValue = false
    if _S.createSpeedDisplay then _S.createSpeedDisplay() end
    if _S.stopAutoFace then _S.stopAutoFace() end
    if _S.stopAntiFall then _S.stopAntiFall() end
    if _S.setupNoSlow then 
        _S.Config.noSlowActive = false
        _S.setupNoSlow()
    end
    _S.Config.backpackAlwaysOn = false
    if _S.Config.brightEnabled then
        local l = game:GetService("Lighting")
        l.ClockTime = 0
        l.Ambient = Color3.new(0,0,0)
        l.GlobalShadows = true
        l.OutdoorAmbient = Color3.new(0,0,0)
        _S.Config.brightEnabled = false
    end
    if _S.startESPUpdate then 
        for k,_ in pairs(_S.Config.espEnabled) do _S.Config.espEnabled[k] = false end
        _S.startESPUpdate()
    end
    if _S.stopZombieCollisionRemoval then _S.stopZombieCollisionRemoval() end
    if _S.stopStandWalk then _S.stopStandWalk() end
    if _S.stopClickTeleport then _S.stopClickTeleport() end
    if _S.stopAutoJump then _S.stopAutoJump() end
    -- 停止医生和牧师线程
    if autoRequestHeal and healLoopThread then task.cancel(healLoopThread); healLoopThread = nil end
    if autoBless and blessLoopThread then task.cancel(blessLoopThread); blessLoopThread = nil end
    if autoRepairBuilding then autoRepairBuilding = false end
    -- 断开自动修桥和自动收集的连接
    if _S.repairBridgeConn then _S.repairBridgeConn:Disconnect(); _S.repairBridgeConn = nil end
    if _S.collectHeartbeat then _S.collectHeartbeat:Disconnect(); _S.collectHeartbeat = nil end
    if _S.collectAddedConn then _S.collectAddedConn:Disconnect(); _S.collectAddedConn = nil end
    -- 断开可能残留的RenderStepped/Heartbeat连接
    if _S.renderConn then _S.renderConn:Disconnect() end
    if _S.aimDotConn then _S.aimDotConn:Disconnect() end
    
    -- 删除UI
    if Windows.Gui then
        Windows.Gui:Destroy()
    elseif Windows._frame then
        Windows._frame.Parent:Destroy()
    elseif Windows.Destroy then
        Windows:Destroy()
    end
    
    -- 等待一帧让所有循环退出，然后强制终止脚本
    task.wait(0.1)
    error("脚本已被用户卸载")
end })
ConfigSection:NewButton({ Title = "重置界面位置", Callback = function() Windows:Notify("请重启脚本",2) end })
ConfigSection:NewToggle({ Title = "显示速度数值", Default = _S.Config.showSpeedValue, Callback = function(s) _S.Config.showSpeedValue = s; _S.createSpeedDisplay() end })

-- 快捷键
_S.UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.H then
        local start = tick()
        local conn
        conn = _S.UserInputService.InputEnded:Connect(function(inp)
            if inp.KeyCode == Enum.KeyCode.H then
                if tick() - start >= 0.5 then Windows:Toggle() end
                conn:Disconnect()
            end
        end)
    end
end)

-- 初始化
_S.updateWalkSpeed()
_S.startESPUpdate()
_S.createSpeedDisplay()
if _S.Config.silentAim or _S.Config.pvpAimEnabled then _S.enableHooks() end
if _S.Config.auraEnabled then _S.startAura() end
if _S.Config.killWaveEnabled then _S.startWaveMode() end
if _S.Config.killAnimEnabled then _S.updateKillAnimConn() end
if _S.Config.autoShoot then _S.startShoot() end
if _S.Config.autoDoorEnabled then task.spawn(_S.autoDoorLoop) end
if _S.Config.autoDig then task.spawn(_S.autoDigLoop) end
if _S.Config.autoLog then task.spawn(_S.autoLogLoop) end
if _S.Config.autoPlace then task.spawn(_S.autoPlaceLoop) end
if _S.Config.autoRepairBridge then
    if _S.repairBridgeConn then _S.repairBridgeConn:Disconnect() end
    _S.repairBridgeConn = _S.RunService.Heartbeat:Connect(_S.doRepairBridge)
end
if _S.Config.autoCollect then _S.setupAutoCollect() end
if _S.Config.hammerAuto then _S.startHammer() end
if _S.Config.engineerRecycle or _S.Config.engineerElbow then _S.updateEngineerConn() end
if _S.Config.autoElbow then _S.startAutoElbow() end
if _S.Config.officerAutoJump then _S.setupOfficerJump() end
_S.toggleHealMove()
_S.toggleFixFire()
_S.toggleNoSpread()
_S.toggleTrajectory()