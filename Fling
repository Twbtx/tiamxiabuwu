local function blurEffect(window, color, transparency)
    color = color or Color3.fromRGB(255, 215, 0)
    transparency = transparency or 0.1
    local frame = window.UIElements and window.UIElements.Main or window.Frame or window.Gui or window
    if not frame then return false end
    local blur = frame:FindFirstChild("Blur", true)
    if blur and blur:IsA("ImageLabel") then
        blur.ImageColor3 = color
        blur.ImageTransparency = transparency
        return true
    end
    local shadow = frame:FindFirstChild("Shadow", true)
    if shadow and shadow:IsA("ImageLabel") then
        shadow.ImageColor3 = color
        shadow.ImageTransparency = transparency
        return true
    end
    return false
end

