function _G.Kspa.SetAntiGrabMode(mode)
    local modes = { "AntiGrabNormal", "AntiGrabFast", "AntiGrabTurbo" }
    for _, m in ipairs(modes) do
        if m ~= mode and _G.Kspa.Toggles[m].Enabled then
            _G.Kspa.Toggles[m].Stop()
        end
    end
    if not _G.Kspa.Toggles[mode].Enabled then
        _G.Kspa.Toggles[mode].Start()
    end
end

